{
  "name": "blueprint",
  "version": "0.1.0",
  "private": true,
  "description": "Blueprint Gemini CLI extension scaffold",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
