{
  "name": "blueprint",
  "description": "Gemini CLI extension for Blueprint's command-driven repository planning, execution, and milestone workflows.",
  "version": "0.1.0",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "blueprint": {
      "command": "node",
      "args": [
        "${extensionPath}/dist/mcp/server.js"
      ],
      "env": {
        "BLUEPRINT_HOST": "gemini",
        "BLUEPRINT_EXTENSION_PATH": "${extensionPath}"
      }
    }
  }
}
