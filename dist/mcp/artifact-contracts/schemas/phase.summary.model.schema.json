{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blueprint.phase.summary.model",
  "title": "Blueprint Phase Summary Model",
  "description": "Model-authored payload for phase.summary. Runtime-owned phase identity, plan id, linked plan path, summary path, and final Markdown persistence are supplied by MCP tools.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "readiness",
    "completionState",
    "outcome",
    "changesMade",
    "targetedVerification",
    "dependencyPlans",
    "manualOrDeferredWork",
    "gapRoutes",
    "followUps",
    "evidence",
    "nextSafeAction"
  ],
  "properties": {
    "status": {
      "$ref": "#/$defs/status"
    },
    "readiness": {
      "$ref": "#/$defs/readiness",
      "description": "Lifecycle readiness rendered in summary metadata."
    },
    "completionState": {
      "$ref": "#/$defs/completionState",
      "description": "Execution debt state for this plan, not a phase-level completion claim."
    },
    "outcome": {
      "type": "array",
      "description": "Concrete outcome bullets rendered under Outcome.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/bulletString"
      }
    },
    "changesMade": {
      "type": "array",
      "description": "Concrete code, config, artifact, or documentation changes rendered under Changes Made.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/bulletString"
      }
    },
    "targetedVerification": {
      "type": "array",
      "description": "Verification rows rendered into the Verification Markdown table. The task schema narrows check values to the selected plan's acceptance criteria.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/verificationRow"
      }
    },
    "dependencyPlans": {
      "type": "array",
      "description": "Dependency plan rows rendered into the Dependency Plans Markdown table. The task schema narrows this to the exact linked dependency plan inventory, including exact empty shape when none exist.",
      "items": {
        "$ref": "#/$defs/dependencyPlanRow"
      }
    },
    "manualOrDeferredWork": {
      "type": "array",
      "description": "Manual or deferred rows rendered into a Markdown table. COMPLETED summaries must use the exact NONE sentinel row.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/manualOrDeferredRow"
      }
    },
    "gapRoutes": {
      "type": "array",
      "description": "Gap or repair rows rendered into a Markdown table. COMPLETED summaries must use the exact NONE sentinel row.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/gapRouteRow"
      }
    },
    "followUps": {
      "type": "array",
      "description": "Concrete follow-up bullets, or the exact single none sentinel for COMPLETED summaries.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/bulletString"
      }
    },
    "evidence": {
      "type": "array",
      "description": "Summary and evidence rows rendered into the Evidence Markdown table.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidenceRow"
      }
    },
    "nextSafeAction": {
      "$ref": "#/$defs/blueprintCommandAction",
      "description": "One implemented Blueprint command token with optional arguments. The task schema narrows this to status-safe actions for the current phase."
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "COMPLETED"
          }
        }
      },
      "then": {
        "properties": {
          "completionState": {
            "const": "complete"
          },
          "targetedVerification": {
            "items": {
              "type": "object",
              "required": [
                "result"
              ],
              "properties": {
                "result": {
                  "const": "pass"
                }
              }
            }
          },
          "manualOrDeferredWork": {
            "minItems": 1,
            "maxItems": 1,
            "items": {
              "$ref": "#/$defs/noManualOrDeferredRow"
            }
          },
          "gapRoutes": {
            "minItems": 1,
            "maxItems": 1,
            "items": {
              "$ref": "#/$defs/noGapRouteRow"
            }
          },
          "followUps": {
            "minItems": 1,
            "maxItems": 1,
            "items": {
              "const": "none"
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "PARTIAL"
          }
        }
      },
      "then": {
        "properties": {
          "readiness": {
            "const": "not-ready-for-validation"
          },
          "completionState": {
            "const": "pending"
          },
          "targetedVerification": {
            "contains": {
              "type": "object",
              "required": [
                "result"
              ],
              "properties": {
                "result": {
                  "enum": [
                    "fail",
                    "blocked",
                    "not-run"
                  ]
                }
              }
            },
            "minContains": 1
          },
          "gapRoutes": {
            "contains": {
              "type": "object",
              "required": [
                "status"
              ],
              "properties": {
                "status": {
                  "enum": [
                    "OPEN",
                    "BLOCKED"
                  ]
                }
              }
            },
            "minContains": 1
          },
          "followUps": {
            "contains": {
              "not": {
                "const": "none"
              }
            },
            "minContains": 1
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "BLOCKED"
          }
        }
      },
      "then": {
        "properties": {
          "readiness": {
            "const": "blocked"
          },
          "completionState": {
            "const": "blocked"
          },
          "targetedVerification": {
            "contains": {
              "type": "object",
              "required": [
                "result"
              ],
              "properties": {
                "result": {
                  "enum": [
                    "fail",
                    "blocked",
                    "not-run"
                  ]
                }
              }
            },
            "minContains": 1
          },
          "gapRoutes": {
            "contains": {
              "type": "object",
              "required": [
                "status"
              ],
              "properties": {
                "status": {
                  "const": "BLOCKED"
                }
              }
            },
            "minContains": 1
          },
          "followUps": {
            "contains": {
              "not": {
                "const": "none"
              }
            },
            "minContains": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "COMPLETED",
        "PARTIAL",
        "BLOCKED"
      ]
    },
    "readiness": {
      "type": "string",
      "enum": [
        "ready-for-validation",
        "not-ready-for-validation",
        "blocked"
      ]
    },
    "completionState": {
      "type": "string",
      "enum": [
        "complete",
        "pending",
        "blocked"
      ]
    },
    "verificationResult": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked",
        "not-run"
      ]
    },
    "manualOrDeferredStatus": {
      "type": "string",
      "enum": [
        "MANUAL",
        "DEFERRED",
        "NONE"
      ]
    },
    "gapRouteStatus": {
      "type": "string",
      "enum": [
        "OPEN",
        "BLOCKED",
        "NONE"
      ]
    },
    "evidenceKind": {
      "type": "string",
      "enum": [
        "artifact",
        "repo-path",
        "command",
        "test",
        "other"
      ]
    },
    "bulletString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?=.*\\S)[^\\r\\n]+$",
      "description": "Non-empty single-line Markdown bullet text. CR/LF is rejected so a model value cannot inject extra list items or headings."
    },
    "tableCellString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?=.*\\S)[^\\r\\n|]+$",
      "description": "Non-empty single-line Markdown table cell. CR/LF and pipe delimiters are rejected to preserve table shape."
    },
    "verificationCheckString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?=.*\\S)[^\\r\\n]+$",
      "description": "Non-empty single-line verification check copied from the selected plan acceptance criteria. CR/LF is rejected; literal pipes are allowed because the runtime renderer escapes them before Markdown persistence."
    },
    "planId": {
      "type": "string",
      "pattern": "^\\d{2,}$"
    },
    "phasePlanPath": {
      "type": "string",
      "pattern": "^\\.blueprint/phases/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+-PLAN\\.md$"
    },
    "blueprintCommandAction": {
      "type": "string",
      "minLength": 4,
      "pattern": "^/blu(?:-[a-z0-9]+(?:-[a-z0-9]+)*)(?:\\s+[A-Za-z0-9._:/=@+-]+)*$",
      "description": "Single Blueprint command token plus optional tokenized arguments. Natural-language wrapping, backticks, pipes, and multi-line text are rejected."
    },
    "verificationRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check",
        "command",
        "result",
        "evidence",
        "notes"
      ],
      "properties": {
        "check": {
          "$ref": "#/$defs/verificationCheckString"
        },
        "command": {
          "$ref": "#/$defs/tableCellString"
        },
        "result": {
          "$ref": "#/$defs/verificationResult"
        },
        "evidence": {
          "$ref": "#/$defs/tableCellString"
        },
        "notes": {
          "$ref": "#/$defs/tableCellString"
        }
      }
    },
    "dependencyPlanRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planId",
        "path",
        "status",
        "evidence"
      ],
      "properties": {
        "planId": {
          "$ref": "#/$defs/planId"
        },
        "path": {
          "$ref": "#/$defs/phasePlanPath"
        },
        "status": {
          "type": "string",
          "enum": [
            "satisfied"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/tableCellString"
        }
      }
    },
    "manualOrDeferredRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "reason",
        "followUp",
        "status"
      ],
      "properties": {
        "item": {
          "$ref": "#/$defs/tableCellString"
        },
        "reason": {
          "$ref": "#/$defs/tableCellString"
        },
        "followUp": {
          "$ref": "#/$defs/tableCellString"
        },
        "status": {
          "$ref": "#/$defs/manualOrDeferredStatus"
        }
      }
    },
    "noManualOrDeferredRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "reason",
        "followUp",
        "status"
      ],
      "properties": {
        "item": {
          "const": "none"
        },
        "reason": {
          "const": "none"
        },
        "followUp": {
          "const": "none"
        },
        "status": {
          "const": "NONE"
        }
      }
    },
    "gapRouteRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap",
        "evidence",
        "repair",
        "status"
      ],
      "properties": {
        "gap": {
          "$ref": "#/$defs/tableCellString"
        },
        "evidence": {
          "$ref": "#/$defs/tableCellString"
        },
        "repair": {
          "$ref": "#/$defs/tableCellString"
        },
        "status": {
          "$ref": "#/$defs/gapRouteStatus"
        }
      }
    },
    "noGapRouteRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap",
        "evidence",
        "repair",
        "status"
      ],
      "properties": {
        "gap": {
          "const": "none"
        },
        "evidence": {
          "const": "none"
        },
        "repair": {
          "const": "none"
        },
        "status": {
          "const": "NONE"
        }
      }
    },
    "evidenceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "source",
        "summary"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/evidenceKind"
        },
        "source": {
          "$ref": "#/$defs/tableCellString"
        },
        "summary": {
          "$ref": "#/$defs/tableCellString"
        }
      }
    }
  }
}
