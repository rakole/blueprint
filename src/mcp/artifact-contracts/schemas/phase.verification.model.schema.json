{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blueprint.phase.verification.model",
  "title": "Blueprint Phase Verification Model",
  "description": "Model-authored payload for phase.verification. Runtime-owned phase identity, artifact kind, paths, completed summary inventory, and final Markdown persistence are supplied by MCP tools.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "coverageSummary",
    "status",
    "gateState",
    "signOff",
    "validationSummary",
    "requirementCoverage",
    "evidenceReviewedSummaryPaths",
    "evidenceMetadata",
    "manualOrDeferredCoverage",
    "gapClassification",
    "gapsFound",
    "suggestedRepairs",
    "nextSafeAction"
  ],
  "properties": {
    "coverageSummary": {
      "$ref": "#/$defs/nonEmptyString",
      "description": "Single-line summary rendered in the top Validation Summary metadata."
    },
    "status": {
      "$ref": "#/$defs/gateState",
      "description": "Model-visible verification status. Must match gateState; runtime renderers keep the Gate section and top marker aligned."
    },
    "gateState": {
      "$ref": "#/$defs/gateState"
    },
    "signOff": {
      "$ref": "#/$defs/nonEmptyString",
      "description": "Single-line sign-off text rendered in metadata and the Gate State section."
    },
    "validationSummary": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      ],
      "description": "Concrete validation observations rendered as Markdown bullets.",
      "x-blueprint-normalizesTo": "array"
    },
    "requirementCoverage": {
      "type": "array",
      "description": "Requirement and task coverage rows rendered into the Requirement / Task Coverage Markdown table.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirementCoverageRow"
      }
    },
    "evidenceReviewedSummaryPaths": {
      "type": "array",
      "description": "Repo-relative completed execution summary artifacts reviewed during validation.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/phaseSummaryPath"
      }
    },
    "evidenceMetadata": {
      "type": "array",
      "description": "Concrete test, command, harness, artifact, or infrastructure metadata rendered as Markdown bullets.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "manualOrDeferredCoverage": {
      "type": "array",
      "description": "Manual-only or deferred coverage rows rendered into a Markdown table. Use an explicit NONE row when no manual or deferred coverage remains.",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/manualOrDeferredCoverageRow"
      }
    },
    "gapClassification": {
      "type": "array",
      "description": "Gap classification rows rendered into a Markdown table. Use an explicit none row when no gaps remain.",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/gapClassificationRow"
      }
    },
    "gapsFound": {
      "type": "array",
      "description": "Concrete gaps or a single explicit none value rendered as Markdown bullets.",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "suggestedRepairs": {
      "type": "array",
      "description": "Concrete repairs or a single explicit none value rendered as Markdown bullets.",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "sessionState": {
      "type": "array",
      "description": "Optional validation session state retained from host/model context and rendered as Markdown bullets when present.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "checkpoint": {
      "$ref": "#/$defs/nonEmptyString",
      "description": "Optional validation checkpoint label rendered when present."
    },
    "testMatrix": {
      "type": "array",
      "description": "Optional validation test or evidence matrix rendered into a Markdown table when present.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/testMatrixRow"
      }
    },
    "resultSummary": {
      "$ref": "#/$defs/resultSummary",
      "description": "Optional validation result counts rendered when present."
    },
    "observedBehavior": {
      "type": "array",
      "description": "Optional observed behavior notes rendered as Markdown bullets when present.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "unresolvedGaps": {
      "type": "array",
      "description": "Optional unresolved validation gaps rendered as Markdown bullets when present.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "structuredGaps": {
      "type": "array",
      "description": "Optional structured gap rows rendered into a Markdown table when present.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/structuredGapRow"
      }
    },
    "followUpFixes": {
      "type": "array",
      "description": "Optional follow-up fix candidates rendered as Markdown bullets when present.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "nextSafeAction": {
      "$ref": "#/$defs/blueprintCommandAction",
      "description": "One single-line Blueprint command token with optional arguments. The task schema may narrow this to the allowed next actions for the current phase."
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "PASS"
          }
        }
      },
      "then": {
        "properties": {
          "gateState": {
            "const": "PASS"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "PARTIAL"
          }
        }
      },
      "then": {
        "properties": {
          "gateState": {
            "const": "PARTIAL"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "const": "BLOCKED"
          }
        }
      },
      "then": {
        "properties": {
          "gateState": {
            "const": "BLOCKED"
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?=.*\\S)[^\\r\\n]+$",
      "description": "Non-empty single-line string with at least one non-whitespace character. CR/LF is rejected because model strings are rendered into Markdown metadata, bullets, or tables."
    },
    "markdownTableCellString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?=.*\\S)[^\\r\\n|]+$",
      "description": "Non-empty single-line Markdown table cell with at least one non-whitespace character. CR/LF and pipe delimiters are rejected to prevent table shape changes."
    },
    "phaseSummaryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\.blueprint/phases/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+-SUMMARY\\.md$",
      "description": "Repo-relative Blueprint execution summary path under .blueprint/phases with no traversal, absolute path, backslash, glob, or table delimiter surface."
    },
    "blueprintCommandAction": {
      "type": "string",
      "minLength": 4,
      "pattern": "^/blu(?:-[a-z0-9]+(?:-[a-z0-9]+)*)(?:\\s+[A-Za-z0-9._:/=@+-]+)*$",
      "description": "Single Blueprint command token plus optional tokenized arguments. Natural-language wrapping, backticks, pipes, and multi-line text are rejected."
    },
    "gateState": {
      "type": "string",
      "enum": [
        "PASS",
        "PARTIAL",
        "BLOCKED"
      ]
    },
    "coverageState": {
      "type": "string",
      "enum": [
        "PASS",
        "COVERED",
        "covered",
        "MANUAL",
        "DEFERRED",
        "BLOCKED"
      ]
    },
    "manualCoverageStatus": {
      "type": "string",
      "enum": [
        "MANUAL",
        "DEFERRED",
        "NONE"
      ]
    },
    "gapClass": {
      "type": "string",
      "enum": [
        "missing-evidence",
        "partial-coverage",
        "manual-only",
        "deferred-test",
        "contradiction",
        "none"
      ]
    },
    "testResult": {
      "type": "string",
      "enum": [
        "pending",
        "pass",
        "issue",
        "skipped",
        "blocked"
      ]
    },
    "structuredGapStatus": {
      "type": "string",
      "enum": [
        "failed",
        "partial",
        "blocked",
        "none"
      ]
    },
    "structuredGapSeverity": {
      "type": "string",
      "enum": [
        "blocker",
        "major",
        "minor",
        "cosmetic",
        "none"
      ]
    },
    "requirementCoverageRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement",
        "taskOrCheck",
        "evidence",
        "coverageState",
        "notes"
      ],
      "properties": {
        "requirement": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "taskOrCheck": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "evidence": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "coverageState": {
          "$ref": "#/$defs/coverageState"
        },
        "notes": {
          "$ref": "#/$defs/markdownTableCellString"
        }
      }
    },
    "manualOrDeferredCoverageRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "whyManualOrDeferred",
        "followUp",
        "status"
      ],
      "properties": {
        "item": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "whyManualOrDeferred": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "followUp": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "status": {
          "$ref": "#/$defs/manualCoverageStatus"
        }
      }
    },
    "gapClassificationRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gapClass",
        "scope",
        "evidence",
        "repair"
      ],
      "properties": {
        "gapClass": {
          "$ref": "#/$defs/gapClass"
        },
        "scope": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "evidence": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "repair": {
          "$ref": "#/$defs/markdownTableCellString"
        }
      }
    },
    "testMatrixRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "test",
        "expectedBehavior",
        "evidence",
        "result",
        "notes"
      ],
      "properties": {
        "number": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "test": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "expectedBehavior": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "evidence": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "result": {
          "$ref": "#/$defs/testResult"
        },
        "notes": {
          "$ref": "#/$defs/markdownTableCellString"
        }
      }
    },
    "resultSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "issues",
        "pending",
        "skipped",
        "blocked"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "issues": {
          "type": "integer",
          "minimum": 0
        },
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "structuredGapRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test",
        "truth",
        "status",
        "severity",
        "reason",
        "followUp"
      ],
      "properties": {
        "test": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "truth": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "status": {
          "$ref": "#/$defs/structuredGapStatus"
        },
        "severity": {
          "$ref": "#/$defs/structuredGapSeverity"
        },
        "reason": {
          "$ref": "#/$defs/markdownTableCellString"
        },
        "followUp": {
          "$ref": "#/$defs/markdownTableCellString"
        }
      }
    }
  }
}
