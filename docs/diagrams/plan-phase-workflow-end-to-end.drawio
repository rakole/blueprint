        <mxCell id="bg-persist" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="4166" width="3080" height="1048" as="geometry" />
        </mxCell>
        <mxCell id="bg-validate" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="5254" width="3080" height="720" as="geometry" />
        </mxCell>
        <mxCell id="bg-route" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="6014" width="3080" height="470" as="geometry" />
        </mxCell>
        <mxCell id="bg-guardrails" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fed7aa;" vertex="1" parent="1">
          <mxGeometry x="40" y="6524" width="3080" height="556" as="geometry" />
        </mxCell>

        <!-- Stage labels -->
        <mxCell id="stage-entry" value="Entry and runtime contract loading" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#1d4ed8;strokeColor=#1d4ed8;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="245" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-resolve" value="1. Resolve" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0f766e;strokeColor=#0f766e;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="844" width="180" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-read" value="2. Read" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#7c3aed;strokeColor=#7c3aed;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="1354" width="180" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-decide" value="3. Decide" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d97706;strokeColor=#d97706;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="2244" width="180" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-execute" value="4. Execute" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0284c7;strokeColor=#0284c7;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="3326" width="180" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-persist" value="5. Persist" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#16a34a;strokeColor=#16a34a;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="4186" width="180" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-validate" value="6. Validate" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#9333ea;strokeColor=#9333ea;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="5274" width="180" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-route" value="7. Route and report" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#047857;strokeColor=#047857;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="6034" width="200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-guardrails" value="Always-on guardrails and glossary" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ea580c;strokeColor=#ea580c;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="6544" width="260" height="38" as="geometry" />
        </mxCell>

        <!-- Entry -->
        <mxCell id="entry-trigger" value="&lt;b&gt;User trigger&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;User runs &lt;code&gt;/blu-plan-phase [phase]&lt;/code&gt;. Direct example: &lt;code&gt;/blu-plan-phase 3&lt;/code&gt;. Root-router form can also dispatch here as &lt;code&gt;/blu plan-phase&lt;/code&gt; only when the runtime catalog marks the command &lt;code&gt;implemented&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="528" width="360" height="148" as="geometry" />
        </mxCell>
        <mxCell id="entry-manifest" value="&lt;b&gt;commands/blu-plan-phase.toml&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: this thin command manifest tells the host to use the &lt;code&gt;blueprint-phase-planning&lt;/code&gt; skill, expose the long-running stage vocabulary, use only the allowed MCP tools for persistence, and require &lt;code&gt;ask_user&lt;/code&gt; gates for overwriting saved plan bodies.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="510" width="440" height="184" as="geometry" />
        </mxCell>
        <mxCell id="entry-skill" value="&lt;b&gt;skills/blueprint-phase-planning/SKILL.md&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: the orchestration contract. It defines Resolve, Read, Decide, Execute, Persist, Validate, Route; names required tools; names optional agents; and keeps config-gated research, UI, overwrite, checker, repair, and routing behavior consistent.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="510" width="420" height="184" as="geometry" />
        </mxCell>
        <mxCell id="entry-contract" value="&lt;b&gt;Loaded rich runtime reference&lt;/b&gt;&lt;br&gt;&lt;code&gt;skills/blueprint-phase-planning/references/plan-phase-runtime-contract.md&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: the deep behavior spec for stage mapping, MCP call order, anti-shallow plan quality, subagent/fallback paths, validation repair, and completion criteria.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="510" width="500" height="184" as="geometry" />
        </mxCell>
        <mxCell id="entry-contract-status" value="&lt;b&gt;Runtime contract status&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Declared and routable status: &lt;code&gt;implemented&lt;/code&gt; when the manifest, primary skill, and required MCP tools are all present. Root &lt;code&gt;/blu&lt;/code&gt;, help, and progress must not recommend planned-only commands.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="510" width="520" height="184" as="geometry" />
        </mxCell>
        <mxCell id="entry-no-write" value="&lt;b&gt;No durable writes yet&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Only instructions and contracts are loaded. No plan file, config file, or state file is changed until Persist. The first plan mutation must be &lt;code&gt;mcp_blueprint_blueprint_phase_plan_write&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="510" width="560" height="184" as="geometry" />
        </mxCell>

        <!-- Resolve -->
        <mxCell id="resolve-visible-status" value="&lt;b&gt;Visible run posture&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The command narrates &lt;code&gt;Resolve&lt;/code&gt; and keeps five fields visible during a long run: resolved scope, active stage, pending gate, execution mode, and next safe action.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="938" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="resolve-tool" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_locate&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_phase_locate&lt;/code&gt;&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhaseLocate(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Find the requested phase or infer it from Blueprint state/roadmap, then return the authoritative phase number, prefix, name, directory, and known artifacts.&lt;br&gt;&lt;b&gt;Returns&lt;/b&gt; &lt;code&gt;found, phaseNumber, phaseName, phaseDir, artifacts, reason&lt;/code&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="900" width="500" height="226" as="geometry" />
        </mxCell>
        <mxCell id="resolve-internals" value="&lt;b&gt;Locate internals&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;ensureRepoRoot&lt;/code&gt; finds the repo safely.&lt;br&gt;&lt;code&gt;normalizePhaseNumber&lt;/code&gt; accepts numeric phase input like &lt;code&gt;3&lt;/code&gt; or &lt;code&gt;03&lt;/code&gt;.&lt;br&gt;&lt;code&gt;findPhaseDirectory&lt;/code&gt; maps the phase to &lt;code&gt;.blueprint/phases/&lt;/code&gt;.&lt;br&gt;&lt;code&gt;toResolvedPhaseLocation&lt;/code&gt; converts the lookup to a write-safe phase location when later mutations need it.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="900" width="520" height="226" as="geometry" />
        </mxCell>
        <mxCell id="resolve-decision" value="&lt;b&gt;Phase resolved?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If yes, continue to Read. If no, stop before drafting anything.&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=10;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="934" width="260" height="158" as="geometry" />
        </mxCell>
        <mxCell id="resolve-stop" value="&lt;b&gt;Unresolved stop path&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Return the exact &lt;code&gt;phase_locate.reason&lt;/code&gt; plus recovery guidance. Safe route is usually &lt;code&gt;/blu-progress&lt;/code&gt;. No plan draft, no raw file write, and no fabricated phase id.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#ef4444;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="924" width="560" height="182" as="geometry" />
        </mxCell>
        <mxCell id="resolve-success" value="&lt;b&gt;Resolved scope&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Carry forward only authoritative returned fields: &lt;code&gt;phaseNumber&lt;/code&gt;, &lt;code&gt;phasePrefix&lt;/code&gt;, &lt;code&gt;phaseName&lt;/code&gt;, &lt;code&gt;phaseDir&lt;/code&gt;, and artifact list. Later MCP calls use the numeric phase, not slugs or filenames invented by the model.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="1118" width="560" height="120" as="geometry" />
        </mxCell>

        <!-- Read -->
        <mxCell id="read-stage" value="&lt;b&gt;Narrate Read&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: collect all saved evidence before drafting. Status metadata alone is not enough; the command must read actual artifact bodies for context, research, UI, validation, review, and existing plans when relevant.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="1438" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="read-contract-policy" value="&lt;b&gt;Contract first&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Command rule: call &lt;code&gt;artifact_contract_read&lt;/code&gt; with &lt;code&gt;artifactId: &quot;phase.plan&quot;&lt;/code&gt; before drafting. Use the live &lt;code&gt;contract.authoringTemplate&lt;/code&gt; as the shape authority, not a copied local template and not scaffold placeholders.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1438" width="440" height="160" as="geometry" />
        </mxCell>
        <mxCell id="read-contract-tool" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_artifact_contract_read&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_artifact_contract_read&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Read the canonical &lt;code&gt;phase.plan&lt;/code&gt; schema: required headings, locked frontmatter markers, placeholder signals, notes, scaffold template, and authoring template." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1418" width="500" height="198" as="geometry" />
        </mxCell>
        <mxCell id="read-contract-internals" value="&lt;b&gt;Contract internals&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Artifact id: &lt;code&gt;phase.plan&lt;/code&gt;.&lt;br&gt;Owner tool: &lt;code&gt;blueprint_phase_plan_write&lt;/code&gt;.&lt;br&gt;Canonical file pattern: &lt;code&gt;.blueprint/phases/&amp;lt;phase-slug&amp;gt;/XX-YY-PLAN.md&lt;/code&gt;.&lt;br&gt;Required headings: &lt;code&gt;Goal, Scope, Tasks, Verification, Must Haves&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="1418" width="520" height="198" as="geometry" />
        </mxCell>
        <mxCell id="read-contract-output" value="&lt;b&gt;Plan-shape truth&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The later draft must preserve frontmatter keys like &lt;code&gt;phase&lt;/code&gt;, &lt;code&gt;plan_id&lt;/code&gt;, &lt;code&gt;wave&lt;/code&gt;, &lt;code&gt;depends_on&lt;/code&gt;, &lt;code&gt;requirements&lt;/code&gt;, &lt;code&gt;files_modified&lt;/code&gt;, &lt;code&gt;read_first&lt;/code&gt;, &lt;code&gt;acceptance_criteria&lt;/code&gt;, and &lt;code&gt;autonomous&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="1418" width="560" height="198" as="geometry" />
        </mxCell>
        <mxCell id="read-context-tools" value="&lt;b&gt;Context and readiness reads&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_context&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_research_status&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Read the roadmap slice, requirements grounding, project brief, workflow posture, mapped codebase summaries when present, and whether context/research/UI artifacts exist and are usable." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1652" width="500" height="202" as="geometry" />
        </mxCell>
        <mxCell id="read-context-internals" value="&lt;b&gt;What these calls provide&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;blueprint_phase_context&lt;/code&gt; gives roadmap goal/success slice, requirements, missing artifacts, workflow posture, and codebase bundle summaries.&lt;br&gt;&lt;code&gt;blueprint_phase_research_status&lt;/code&gt; gives &lt;code&gt;hasUsableContext&lt;/code&gt;, &lt;code&gt;hasUsableResearch&lt;/code&gt;, &lt;code&gt;hasUsableUiSpec&lt;/code&gt;, validation issues, suggested repairs, and warnings.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="1652" width="520" height="202" as="geometry" />
        </mxCell>
        <mxCell id="read-artifact-tools" value="&lt;b&gt;Actual artifact body reads&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_artifact_read&lt;/code&gt;&lt;br&gt;&lt;b&gt;Artifacts&lt;/b&gt; &lt;code&gt;context, discussion-log, research, ui-spec&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Load the saved markdown text that will ground the plan. Do not draft from readiness booleans alone." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="1888" width="500" height="204" as="geometry" />
        </mxCell>
        <mxCell id="read-artifact-output" value="&lt;b&gt;Discovery evidence loaded&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Typical inputs: &lt;code&gt;XX-CONTEXT.md&lt;/code&gt;, &lt;code&gt;XX-DISCUSSION-LOG.md&lt;/code&gt;, &lt;code&gt;XX-RESEARCH.md&lt;/code&gt;, and &lt;code&gt;XX-UI-SPEC.md&lt;/code&gt;. Missing artifacts become explicit uncertainty or route blockers, not invented evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="1888" width="560" height="204" as="geometry" />
        </mxCell>
        <mxCell id="read-plan-tools" value="&lt;b&gt;Existing plan and evidence reads&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_index&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_read&lt;/code&gt; when revising/replacing&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_validation_read&lt;/code&gt; when verification/UAT evidence exists&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_review_load_findings&lt;/code&gt; when review findings exist&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;See what is already planned or validated before changing plan content." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1874" width="440" height="236" as="geometry" />
        </mxCell>
        <mxCell id="read-config-state-tools" value="&lt;b&gt;Config and state reads&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_config_get&lt;/code&gt; with &lt;code&gt;scope: &quot;effective&quot;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_state_load&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Read normalized workflow gates and current routing/status before deciding whether planning is allowed, skipped, checked, or routed elsewhere." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="1874" width="420" height="236" as="geometry" />
        </mxCell>

        <!-- Decide -->
        <mxCell id="decide-stage" value="&lt;b&gt;Narrate Decide&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: before authoring, compare phase evidence against normalized config gates, existing plan inventory, overwrite risk, and command implementation safety. The command names the active gate instead of silently guessing defaults.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="2330" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="decide-research-gate" value="&lt;b&gt;Gate: &lt;code&gt;workflow.research&lt;/code&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;true&lt;/b&gt;: require usable context and research before final plan authoring. If missing, route to &lt;code&gt;/blu-research-phase&lt;/code&gt; instead of inventing evidence or browsing live docs.&lt;br&gt;&lt;b&gt;false&lt;/b&gt;: explicitly say research was skipped because normalized config disabled it.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="2310" width="440" height="206" as="geometry" />
        </mxCell>
        <mxCell id="decide-ui-gate" value="&lt;b&gt;Gate: &lt;code&gt;workflow.ui_phase&lt;/code&gt; and &lt;code&gt;workflow.ui_safety_gate&lt;/code&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;ui_phase=true&lt;/b&gt;: require usable UI contract for UI work or a documented skip rationale.&lt;br&gt;&lt;b&gt;ui_safety_gate=true&lt;/b&gt;: do not silently omit UI work in scope; require rationale or route to &lt;code&gt;/blu-ui-phase&lt;/code&gt;.&lt;br&gt;&lt;b&gt;disabled&lt;/b&gt;: report the config-disabled skip plainly.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="2310" width="420" height="206" as="geometry" />
        </mxCell>
        <mxCell id="decide-plan-check-gate" value="&lt;b&gt;Gate: &lt;code&gt;workflow.plan_check&lt;/code&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;true&lt;/b&gt;: run a requirements-aware checker loop before final acceptance. Use &lt;code&gt;blueprint-checker&lt;/code&gt; when suitable, otherwise inline fallback.&lt;br&gt;&lt;b&gt;false&lt;/b&gt;: skip checker review entirely and say the normalized config disabled it. Do not pretend a checker passed.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="2310" width="500" height="206" as="geometry" />
        </mxCell>
        <mxCell id="decide-gate-internals" value="&lt;b&gt;Decision evidence&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Sources: &lt;code&gt;config_get(scope=effective)&lt;/code&gt;, &lt;code&gt;phase_research_status&lt;/code&gt;, actual artifact bodies, &lt;code&gt;phase_context.workflowPosture&lt;/code&gt;, and current &lt;code&gt;STATE.md&lt;/code&gt;. Missing evidence is a blocker or route, not a prompt-only assumption.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="2310" width="520" height="206" as="geometry" />
        </mxCell>
        <mxCell id="decide-route-blockers" value="&lt;b&gt;Gate outcome: route before planning when needed&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Possible safe routes: &lt;code&gt;/blu-research-phase &amp;lt;phase&amp;gt;&lt;/code&gt;, &lt;code&gt;/blu-ui-phase &amp;lt;phase&amp;gt;&lt;/code&gt;, or &lt;code&gt;/blu-progress&lt;/code&gt;. The command routes only to implemented commands and names the missing artifact or rationale.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#ef4444;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="2310" width="560" height="206" as="geometry" />
        </mxCell>
        <mxCell id="decide-overwrite-gate" value="&lt;b&gt;Gate: saved plan mutation risk&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If the current write would revise or replace an existing plan id or saved plan set, read affected plans through &lt;code&gt;phase_plan_read&lt;/code&gt; and use &lt;code&gt;ask_user&lt;/code&gt; for &lt;code&gt;reuse&lt;/code&gt;, &lt;code&gt;revise&lt;/code&gt;, or &lt;code&gt;replace&lt;/code&gt;. Replacement requires explicit confirmation. Additive new plan ids may proceed without this gate when no saved body is overwritten.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="2570" width="440" height="226" as="geometry" />
        </mxCell>
        <mxCell id="decide-ask-user" value="&lt;b&gt;Host interaction: &lt;code&gt;ask_user&lt;/code&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: ask one focused choice question when overwriting or choosing reuse/revise/replace. Use 2-4 labeled options and keep custom-answer path open. No confirmation means no destructive plan write.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="2580" width="360" height="206" as="geometry" />
        </mxCell>
        <mxCell id="decide-plan-index" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_index&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Index existing &lt;code&gt;XX-YY-PLAN.md&lt;/code&gt; files, dependency waves, missing plan prerequisites, and gap-closure plans. This is how the command knows whether it is appending, revising, or replacing.&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhasePlanIndex(args)&lt;/code&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="2570" width="500" height="226" as="geometry" />
        </mxCell>
        <mxCell id="decide-plan-read" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_read&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Load the exact saved plan body and parsed metadata for a numeric &lt;code&gt;planId&lt;/code&gt; before revising or replacing it. Returns content, frontmatter-derived metadata, validation issues, and canonical path.&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhasePlanRead(args)&lt;/code&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="2570" width="520" height="226" as="geometry" />
        </mxCell>
        <mxCell id="decide-scope-sanity" value="&lt;b&gt;Scope sanity gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If the phase cannot be planned without reducing locked decisions or dropping must-haves, recommend a split or prioritization before persistence. Do not use &lt;code&gt;v1&lt;/code&gt;, &lt;code&gt;simplified&lt;/code&gt;, &lt;code&gt;placeholder&lt;/code&gt;, &lt;code&gt;future enhancement&lt;/code&gt;, &lt;code&gt;not connected&lt;/code&gt;, or &lt;code&gt;stub&lt;/code&gt; to shrink user intent silently.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#ef4444;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="2570" width="560" height="226" as="geometry" />
        </mxCell>
        <mxCell id="decide-authoring-checklist" value="&lt;b&gt;Pre-authoring checklist&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The final draft must map every declared phase requirement, keep dependency waves acyclic, name concrete repo paths in &lt;code&gt;Read First&lt;/code&gt;, include concrete target-state &lt;code&gt;Action&lt;/code&gt; text, and make acceptance criteria grep/test/CLI/file-read verifiable.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="2860" width="420" height="184" as="geometry" />
        </mxCell>
        <mxCell id="decide-continue" value="&lt;b&gt;All gates satisfied?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Yes: move to Execute drafting. No: route, ask, split, or stop with a named blocker. The workflow never drafts around a known missing prerequisite by pretending it exists.&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=10;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1520" y="2862" width="290" height="172" as="geometry" />
        </mxCell>

        <!-- Execute -->
        <mxCell id="execute-stage" value="&lt;b&gt;Narrate Execute&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: now synthesize actual plan bodies from evidence. The parent command still owns MCP calls, user gates, persistence, validation, state updates, and final routing.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="3410" width="360" height="156" as="geometry" />
        </mxCell>
        <mxCell id="execute-parent-packet" value="&lt;b&gt;Planner packet assembled by parent&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Inputs include: resolved phase, live &lt;code&gt;phase.plan&lt;/code&gt; contract, roadmap goal, requirements, actual context text, actual research/UI/validation/review content when present, effective config, mapped codebase summaries, existing plan contents for revision, and checker findings during revision.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="3410" width="440" height="196" as="geometry" />
        </mxCell>
        <mxCell id="execute-planner" value="&lt;b&gt;Optional agent: &lt;code&gt;blueprint-planner&lt;/code&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: a bounded read-only specialist drafts complete &lt;code&gt;XX-YY-PLAN.md&lt;/code&gt; bodies, requirement coverage mapping, dependency waves, split rationale, blockers, assumptions, and revision notes. It does not persist files, update state, or choose final acceptance.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;strokeWidth=2;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="3388" width="420" height="240" as="geometry" />
        </mxCell>
        <mxCell id="execute-no-agent" value="&lt;b&gt;No-subagent fallback&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If suitable agents are unavailable, continue sequentially: compress evidence into a carry-forward note, draft one plan/topic at a time from &lt;code&gt;authoringTemplate&lt;/code&gt;, run the inline quality checklist, persist only after the current plan passes, and then move to the next dependency wave.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="3662" width="420" height="226" as="geometry" />
        </mxCell>
        <mxCell id="execute-draft-rules" value="&lt;b&gt;Draft quality rules&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Every task includes &lt;code&gt;#### Read First&lt;/code&gt;, &lt;code&gt;#### Action&lt;/code&gt;, and &lt;code&gt;#### Acceptance Criteria&lt;/code&gt;. Plans usually have 2-3 tasks. Four tasks is a warning; five or more tasks, more than about eight files, or one task touching more than five files should trigger split review.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="3388" width="520" height="240" as="geometry" />
        </mxCell>
        <mxCell id="execute-draft-output" value="&lt;b&gt;Draft output before persistence&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Complete plan bodies only: not outlines, not notes, not scaffold text. Drafts are normalized to the live &lt;code&gt;contract.authoringTemplate&lt;/code&gt;. Requirement coverage, dependency waves, blockers, and assumptions are preserved for review and final summary.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="3388" width="560" height="240" as="geometry" />
        </mxCell>
        <mxCell id="execute-checker" value="&lt;b&gt;Optional agent: &lt;code&gt;blueprint-checker&lt;/code&gt;&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Runs only when &lt;code&gt;workflow.plan_check=true&lt;/code&gt; and suitable. Plain English: a bounded read-only reviewer checks goal alignment, requirement coverage, artifact quality, dependency correctness, config compliance, scope sanity, verification readiness, anti-shallow readiness, scope reduction, scope budget, must-have quality, and Blueprint rule compliance.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;strokeWidth=2;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="3672" width="500" height="250" as="geometry" />
        </mxCell>
        <mxCell id="execute-checker-verdict" value="&lt;b&gt;Checker verdict loop&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;ACCEPT&lt;/code&gt;: review says the draft is ready, but parent still owns persistence.&lt;br&gt;&lt;code&gt;REVISE&lt;/code&gt;: revise only affected plan ids unless the whole set is unsound.&lt;br&gt;&lt;code&gt;BLOCK&lt;/code&gt;: stop or split unless missing substrate can be produced by an implemented command.&lt;br&gt;Max loop: three checker passes; after that report unresolved issues and route safely unless user explicitly chooses a risky proceed path.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="3672" width="520" height="250" as="geometry" />
        </mxCell>
        <mxCell id="execute-ready" value="&lt;b&gt;Finalized draft ready for MCP write&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The command now has one or more plan bodies that preserve locked decisions, cover requirements or name blockers, use exact paths, define concrete actions, and expose mechanically checkable acceptance criteria. Persistence has still not happened yet.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="3672" width="560" height="250" as="geometry" />
        </mxCell>

        <!-- Persist -->
        <mxCell id="persist-stage" value="&lt;b&gt;Narrate Persist&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: this is the only point where the command writes plan artifacts. It never seeds scaffold placeholders as final content and never writes raw &lt;code&gt;.blueprint/&lt;/code&gt; files directly.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="4270" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="persist-call" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_write&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_phase_plan_write&lt;/code&gt;&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhasePlanWrite(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Required args for this command&lt;/b&gt;&lt;br&gt;&lt;code&gt;phase&lt;/code&gt;: resolved numeric phase. &lt;code&gt;content&lt;/code&gt;: full plan body. &lt;code&gt;validationMode: &quot;strict&quot;&lt;/code&gt;. Omit &lt;code&gt;planId&lt;/code&gt; to auto-assign, or pass only numeric plan id like &lt;code&gt;&quot;01&quot;&lt;/code&gt; when targeting a slot.&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Ask Blueprint to validate and save the plan safely.&lt;br&gt;&lt;b&gt;Forbidden args&lt;/b&gt;&lt;br&gt;No phase directory, slug, filename, combined token like &lt;code&gt;02-01&lt;/code&gt;, frontmatter key name, or &lt;code&gt;validationMode: &quot;warn&quot;&lt;/code&gt; from &lt;code&gt;/blu-plan-phase&lt;/code&gt;." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="4264" width="440" height="344" as="geometry" />
        </mxCell>
        <mxCell id="persist-internals-1" value="&lt;b&gt;Write internals: preparation&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;resolveLocatedPhaseForMutation&lt;/code&gt; resolves repo root and phase or throws exact locate failure.&lt;br&gt;&lt;code&gt;withBlueprintRepoLock(projectRoot, &quot;phase-plan-write&quot;)&lt;/code&gt; serializes the mutation.&lt;br&gt;&lt;code&gt;blueprintPhasePlanIndex&lt;/code&gt; finds existing plan ids.&lt;br&gt;&lt;code&gt;normalizePlanId&lt;/code&gt; rejects zero and normalizes numeric ids.&lt;br&gt;&lt;code&gt;planPathFor&lt;/code&gt; derives the canonical &lt;code&gt;XX-YY-PLAN.md&lt;/code&gt; path.&lt;br&gt;&lt;code&gt;reconcileAutoAssignedPlanContent&lt;/code&gt; replaces &lt;code&gt;YY&lt;/code&gt; in &lt;code&gt;plan_id&lt;/code&gt;, title, and H1 when &lt;code&gt;planId&lt;/code&gt; is omitted.&lt;br&gt;&lt;code&gt;prepareTextForPersistence&lt;/code&gt; normalizes text and applies prompt/path safety checks.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="4264" width="420" height="344" as="geometry" />
        </mxCell>
        <mxCell id="persist-internals-2" value="&lt;b&gt;Write internals: validation before disk&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;validatePlanArtifactContent(preparedContent, expectedPhase, {strict})&lt;/code&gt; checks frontmatter, required sections, placeholders, concrete paths, checkable acceptance criteria, verification, and must-haves.&lt;br&gt;&lt;code&gt;collectInvalidPlanDependencyIssues&lt;/code&gt; catches non-numeric dependency refs.&lt;br&gt;Frontmatter &lt;code&gt;plan_id&lt;/code&gt; must match requested &lt;code&gt;planId&lt;/code&gt;.&lt;br&gt;&lt;code&gt;validatePhasePlanSet(...overrides, roadmapCoverageSeverity=&quot;warning&quot;)&lt;/code&gt; validates the prospective full set before writing.&lt;br&gt;&lt;code&gt;selectRelevantPlanValidationIssues&lt;/code&gt; blocks only relevant strict issues for this write.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="4264" width="500" height="344" as="geometry" />
        </mxCell>
        <mxCell id="persist-invalid" value="&lt;b&gt;Strict write rejected?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If dependency issues, missing frontmatter/sections, placeholder-only content, mismatched &lt;code&gt;plan_id&lt;/code&gt;, unsafe text, or relevant plan-set issues appear, the tool returns &lt;code&gt;status: &quot;invalid&quot;&lt;/code&gt;, &lt;code&gt;written: false&lt;/code&gt;, issues, and warnings. The command repairs against the live contract and retries through MCP. It does not bypass with raw file writes.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#ef4444;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1960" y="4264" width="520" height="344" as="geometry" />
        </mxCell>
        <mxCell id="persist-output-invalid" value="&lt;b&gt;Repair loop input&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The command feeds validation issues back into targeted revision. Common repairs: fill required headings, replace scaffold placeholders, fix objective/read paths/acceptance criteria, remove scope-reduction language, fix dependencies/waves, align &lt;code&gt;plan_id&lt;/code&gt;, or split the plan.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="4264" width="560" height="344" as="geometry" />
        </mxCell>
        <mxCell id="persist-existing" value="&lt;b&gt;Existing file handling&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;pathExists&lt;/code&gt; checks if the canonical plan path already exists. If the normalized existing content is unchanged, the result is &lt;code&gt;status: &quot;reused&quot;&lt;/code&gt; and no write happens. If content differs and &lt;code&gt;overwrite&lt;/code&gt; is not true, the tool throws an explicit overwrite-confirmation error.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="4660" width="420" height="214" as="geometry" />
        </mxCell>
        <mxCell id="persist-write-disk" value="&lt;b&gt;Actual write&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;writeTextFile(absolutePath, preparedContent.content)&lt;/code&gt; writes only after validation and overwrite rules pass.&lt;br&gt;&lt;b&gt;Statuses&lt;/b&gt;: &lt;code&gt;created&lt;/code&gt; for new plan, &lt;code&gt;updated&lt;/code&gt; for confirmed overwrite, &lt;code&gt;reused&lt;/code&gt; for identical content, &lt;code&gt;invalid&lt;/code&gt; for rejected strict writes.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="4660" width="500" height="214" as="geometry" />
        </mxCell>
        <mxCell id="persist-artifact" value="&lt;b&gt;Durable output&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;One real plan file under the selected phase directory, for example &lt;code&gt;.blueprint/phases/03-phase-discovery/03-01-PLAN.md&lt;/code&gt;. The returned &lt;code&gt;phaseNumber&lt;/code&gt;, &lt;code&gt;phasePrefix&lt;/code&gt;, &lt;code&gt;phaseName&lt;/code&gt;, &lt;code&gt;phaseDir&lt;/code&gt;, &lt;code&gt;planId&lt;/code&gt;, &lt;code&gt;path&lt;/code&gt;, &lt;code&gt;written&lt;/code&gt;, &lt;code&gt;created&lt;/code&gt;, &lt;code&gt;overwritten&lt;/code&gt;, &lt;code&gt;status&lt;/code&gt;, &lt;code&gt;validation&lt;/code&gt;, and &lt;code&gt;warnings&lt;/code&gt; become authoritative.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="4660" width="560" height="214" as="geometry" />
        </mxCell>
        <mxCell id="persist-multiple" value="&lt;b&gt;Multiple plans&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;For a plan set, repeat the write path for each finalized plan body. Additive auto-assignment can create &lt;code&gt;01&lt;/code&gt;, &lt;code&gt;02&lt;/code&gt;, etc. Targeted revisions pass only the numeric &lt;code&gt;planId&lt;/code&gt; confirmed by the overwrite gate.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="4916" width="360" height="162" as="geometry" />
        </mxCell>
        <mxCell id="persist-not-done" value="&lt;b&gt;Persist is not completion&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;A successful plan write saves an artifact, but the command still must validate the scoped plan set and sync state before reporting completion. This prevents a locally valid individual file from hiding dependency, wave, title, heading, or roadmap coverage drift across the plan set.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="4916" width="440" height="162" as="geometry" />
        </mxCell>

        <!-- Validate -->
        <mxCell id="validate-stage" value="&lt;b&gt;Narrate Validate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: after the final write path, ask Blueprint to validate the whole saved plan set for this phase. This is separate from individual write validation.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="5358" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="validate-call" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_validate&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_phase_plan_validate&lt;/code&gt;&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhasePlanValidate(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Validate all saved plans for one phase: canonical filenames, frontmatter, title and heading slot consistency, phase match, dependency existence, wave order, dependency cycles, and roadmap requirement coverage." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="5358" width="440" height="250" as="geometry" />
        </mxCell>
        <mxCell id="validate-internals" value="&lt;b&gt;Validation internals&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;collectPhasePlanArtifacts&lt;/code&gt; enumerates &lt;code&gt;*-PLAN.md&lt;/code&gt; files in the phase dir.&lt;br&gt;&lt;code&gt;parsePlanArtifactPath&lt;/code&gt; rejects non-canonical names.&lt;br&gt;&lt;code&gt;validatePlanArtifactContent&lt;/code&gt; parses plan metadata and body quality.&lt;br&gt;&lt;code&gt;readPhaseRoadmapRequirements&lt;/code&gt; loads requirement ids from &lt;code&gt;ROADMAP.md&lt;/code&gt;.&lt;br&gt;&lt;code&gt;detectDependencyCycles&lt;/code&gt; finds dependency loops.&lt;br&gt;The validator also checks duplicated frontmatter ids, title/heading &lt;code&gt;YY&lt;/code&gt; placeholders, phase-name mismatches, missing dependencies, wrong wave ordering, unexpected requirements, and uncovered requirements.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="5358" width="420" height="436" as="geometry" />
        </mxCell>
        <mxCell id="validate-result" value="&lt;b&gt;Validation result&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Returns &lt;code&gt;status&lt;/code&gt;, &lt;code&gt;issues&lt;/code&gt;, &lt;code&gt;warnings&lt;/code&gt;, &lt;code&gt;planCount&lt;/code&gt;, &lt;code&gt;planIds&lt;/code&gt;, &lt;code&gt;roadmapRequirementIds&lt;/code&gt;, &lt;code&gt;coveredRequirementIds&lt;/code&gt;, &lt;code&gt;uncoveredRequirementIds&lt;/code&gt;, &lt;code&gt;unexpectedRequirementIds&lt;/code&gt;, &lt;code&gt;missingDependencyIds&lt;/code&gt;, and &lt;code&gt;cyclicDependencyPlanIds&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="5358" width="560" height="250" as="geometry" />
        </mxCell>
        <mxCell id="validate-gate" value="&lt;b&gt;Saved plan set valid?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If valid, continue to Route. If invalid, do not present the plan as complete.&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=10;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1518" y="5400" width="300" height="178" as="geometry" />
        </mxCell>
        <mxCell id="validate-repair" value="&lt;b&gt;Validation repair path&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Repair only affected plan ids or split point. Re-run the targeted planner/checker path if needed. Write repaired content again through &lt;code&gt;phase_plan_write&lt;/code&gt;, then call &lt;code&gt;phase_plan_validate&lt;/code&gt; again. If repair stalls, report the remaining blocker or split point and route to &lt;code&gt;/blu-progress&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#ef4444;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="5630" width="500" height="210" as="geometry" />
        </mxCell>
        <mxCell id="validate-success" value="&lt;b&gt;Validated plan set&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The saved plans now satisfy the scoped validation contract or any remaining warnings are truthfully named. This makes the downstream execute-phase target selection deterministic and lowers review ambiguity.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="5630" width="560" height="210" as="geometry" />
        </mxCell>

        <!-- Route -->
        <mxCell id="route-stage" value="&lt;b&gt;Narrate Route&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: now refresh Blueprint state from the updated artifact inventory and report what changed plus the next safe implemented action.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="6118" width="360" height="154" as="geometry" />
        </mxCell>
        <mxCell id="route-state-update" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_state_update&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_state_update&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Patch &lt;code&gt;.blueprint/STATE.md&lt;/code&gt; deterministically. &lt;code&gt;/blu-plan-phase&lt;/code&gt; should call it with &lt;code&gt;base: &quot;synced&quot;&lt;/code&gt; so next action is recomputed from current artifacts instead of stale chat memory.&lt;br&gt;&lt;b&gt;Returns&lt;/b&gt; &lt;code&gt;updatedFields, statePath, warnings&lt;/code&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="6098" width="440" height="220" as="geometry" />
        </mxCell>
        <mxCell id="route-implemented-only" value="&lt;b&gt;Implemented-only routing&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Next action can be &lt;code&gt;/blu-execute-phase &amp;lt;phase&amp;gt;&lt;/code&gt; when the plan set is ready and the command is implemented. If the natural next command is not implemented or the safest next step is ambiguous, route to &lt;code&gt;/blu-progress&lt;/code&gt; instead. Never recommend planned-only lifecycle commands as runnable.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="6098" width="420" height="220" as="geometry" />
        </mxCell>
        <mxCell id="route-summary" value="&lt;b&gt;Final user response&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Concise summary covers: phase, config gates enabled/skipped, plan ids added/revised/replaced/reused, checker behavior or config-disabled skip, warnings/blockers, validation outcome, state update, and next safe implemented action. It does not claim research, UI, or checker work happened when config disabled it.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="6098" width="500" height="220" as="geometry" />
        </mxCell>
        <mxCell id="route-artifacts" value="&lt;b&gt;Final durable state&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;.blueprint/phases/&amp;lt;phase-slug&amp;gt;/XX-YY-PLAN.md&lt;/code&gt; files exist or are truthfully reused.&lt;br&gt;&lt;code&gt;.blueprint/STATE.md&lt;/code&gt; reflects synced routing.&lt;br&gt;No unrelated repo files, installed extension files, or global Blueprint state were mutated by this command.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2520" y="6098" width="560" height="220" as="geometry" />
        </mxCell>

        <!-- Guardrails and glossary -->
        <mxCell id="guardrail-mcp-only" value="&lt;b&gt;Persistence guardrail&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Allowed persistent state tools for this command only: &lt;code&gt;phase_locate&lt;/code&gt;, &lt;code&gt;artifact_contract_read&lt;/code&gt;, &lt;code&gt;phase_context&lt;/code&gt;, &lt;code&gt;phase_research_status&lt;/code&gt;, &lt;code&gt;phase_artifact_read&lt;/code&gt;, &lt;code&gt;phase_validation_read&lt;/code&gt;, &lt;code&gt;review_load_findings&lt;/code&gt;, &lt;code&gt;phase_plan_index&lt;/code&gt;, &lt;code&gt;phase_plan_read&lt;/code&gt;, &lt;code&gt;phase_plan_validate&lt;/code&gt;, &lt;code&gt;phase_plan_write&lt;/code&gt;, &lt;code&gt;config_get&lt;/code&gt;, &lt;code&gt;state_load&lt;/code&gt;, and &lt;code&gt;state_update&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="6620" width="580" height="190" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-no-web" value="&lt;b&gt;Evidence guardrail&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Do not browse live web docs during planning. Use saved research for unstable technical decisions. If required research is missing or stale under active gates, route to &lt;code&gt;/blu-research-phase&lt;/code&gt; instead. Optional agents cannot be browser/web-search-only substitutes.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="6620" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-state-boundary" value="&lt;b&gt;State boundary&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Writes stay inside the selected &lt;code&gt;.blueprint/phases/&amp;lt;phase-slug&amp;gt;/&lt;/code&gt; directory plus &lt;code&gt;.blueprint/STATE.md&lt;/code&gt;. &lt;code&gt;.planning/&lt;/code&gt; is local implementation bookkeeping only. Hooks are advisory; they do not own phase state transitions.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1260" y="6620" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-quality" value="&lt;b&gt;Quality bar glossary&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;Read First&lt;/code&gt;: exact repo paths and sources of truth.&lt;br&gt;&lt;code&gt;Action&lt;/code&gt;: concrete target behavior, functions, routes, schema fields, config keys, imports, values, and decisions.&lt;br&gt;&lt;code&gt;Acceptance Criteria&lt;/code&gt;: mechanically checkable grep/test/CLI/file-read/manual checkpoints.&lt;br&gt;&lt;code&gt;Must Haves&lt;/code&gt;: observable truths, required artifacts, and key links or wiring points.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1820" y="6620" width="600" height="190" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-tool-results" value="&lt;b&gt;Returned values are authoritative&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Use returned &lt;code&gt;phaseNumber&lt;/code&gt;, &lt;code&gt;phasePrefix&lt;/code&gt;, &lt;code&gt;phaseDir&lt;/code&gt;, &lt;code&gt;planId&lt;/code&gt;, &lt;code&gt;path&lt;/code&gt;, validation issues, warnings, and state path. Do not invent filenames, dependency ids, or next actions from prose when MCP returned canonical values.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2460" y="6620" width="620" height="190" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-sources" value="&lt;b&gt;Source files reflected in this diagram&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;commands/blu-plan-phase.toml&lt;/code&gt;, &lt;code&gt;docs/commands/plan-phase.md&lt;/code&gt;, &lt;code&gt;skills/blueprint-phase-planning/SKILL.md&lt;/code&gt;, &lt;code&gt;skills/blueprint-phase-planning/references/plan-phase-runtime-contract.md&lt;/code&gt;, &lt;code&gt;agents/blueprint-planner.md&lt;/code&gt;, &lt;code&gt;agents/blueprint-checker.md&lt;/code&gt;, &lt;code&gt;docs/MCP-TOOLS.md&lt;/code&gt;, &lt;code&gt;docs/PHASE-LIFECYCLE.md&lt;/code&gt;, &lt;code&gt;src/mcp/tools/phase.ts&lt;/code&gt;, and &lt;code&gt;src/mcp/artifact-contracts/index.ts&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="6840" width="3000" height="140" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="edge-entry-resolve" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="entry-trigger" target="resolve-visible-status">
