<mxfile host="app.diagrams.net" modified="2026-04-28T00:00:00.000Z" agent="codex" version="24.7.8">
  <diagram id="plan-phase-workflow-end-to-end" name="plan-phase workflow end-to-end">
    <mxGraphModel dx="3160" dy="7160" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3160" pageHeight="7160" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Canvas -->
        <mxCell id="canvas" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3160" height="7160" as="geometry" />
        </mxCell>

        <!-- Title and legend -->
        <mxCell id="title" value="&lt;div style=&quot;font-size:32px;font-weight:700;&quot;&gt;/blu-plan-phase end-to-end workflow&lt;/div&gt;&lt;div style=&quot;font-size:15px;margin-top:8px;&quot;&gt;Exhaustive presentation map from user trigger through stage narration, config gates, MCP-owned plan persistence, validation repair loops, synced state update, and final routing. Internal names are paired with plain-English explanations in each relevant card.&lt;/div&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0f172a;gradientColor=#1e293b;strokeColor=#0f172a;fontColor=#ffffff;align=center;verticalAlign=middle;shadow=1;spacing=18;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="3080" height="118" as="geometry" />
        </mxCell>
        <mxCell id="legend-type" value="&lt;b&gt;Diagram type: swimlane activity map&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Read top to bottom. Within each stage, scan left to right: user/host, command/skill policy, optional agents, MCP calls, tool internals, then durable artifacts and route results. Blue arrows show the main happy path; orange/red cards show gates and stop paths; dashed cards show optional capability-gated paths.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#0f172a;spacing=14;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="176" width="860" height="122" as="geometry" />
        </mxCell>
        <mxCell id="legend-name-pattern" value="&lt;b&gt;Name pattern used below&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Runtime FQN&lt;/b&gt;: &lt;code&gt;mcp_blueprint_blueprint_phase_plan_write&lt;/code&gt;&lt;br&gt;&lt;b&gt;Registered MCP tool&lt;/b&gt;: &lt;code&gt;blueprint_phase_plan_write&lt;/code&gt;&lt;br&gt;&lt;b&gt;TypeScript handler&lt;/b&gt;: &lt;code&gt;blueprintPhasePlanWrite(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;: save one real phase plan through Blueprint validation, not by hand-editing &lt;code&gt;.blueprint/&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="176" width="760" height="122" as="geometry" />
        </mxCell>
        <mxCell id="legend-core-invariant" value="&lt;b&gt;Core invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Commands own user experience. Skills own orchestration policy. Optional agents own bounded read-only drafting or review. MCP tools own deterministic state reads and writes. Runtime state is &lt;code&gt;.blueprint/&lt;/code&gt;; &lt;code&gt;.planning/&lt;/code&gt; and raw filesystem writes are not Blueprint runtime persistence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1740" y="176" width="640" height="122" as="geometry" />
        </mxCell>
        <mxCell id="legend-completion" value="&lt;b&gt;Workflow completion means&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;A valid &lt;code&gt;phase.plan&lt;/code&gt; contract was read, enabled gates were honored or safely routed, saved plans were added/revised/reused through MCP, the saved plan set was validated, &lt;code&gt;STATE.md&lt;/code&gt; was synced, and only an implemented next action was recommended.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#1e3a8a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2420" y="176" width="700" height="122" as="geometry" />
        </mxCell>

        <!-- Column headers -->
        <mxCell id="col-user" value="User and Gemini host" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="80" y="346" width="360" height="54" as="geometry" />
        </mxCell>
        <mxCell id="col-command" value="Command manifest and skill" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontColor=#0f172a;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="480" y="346" width="440" height="54" as="geometry" />
        </mxCell>
        <mxCell id="col-agents" value="Optional agents and inline fallback" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="960" y="346" width="420" height="54" as="geometry" />
