        <mxCell id="col-internals" value="Tool internals and decisions" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="1960" y="346" width="520" height="54" as="geometry" />
        </mxCell>
        <mxCell id="col-artifacts" value="Artifacts, outputs, and routes" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="2520" y="346" width="560" height="54" as="geometry" />
        </mxCell>

        <!-- Stage backgrounds -->
        <mxCell id="bg-entry" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="3080" height="354" as="geometry" />
        </mxCell>
