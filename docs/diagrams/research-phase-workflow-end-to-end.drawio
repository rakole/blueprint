        <mxCell id="bg-validate" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="5310" width="2940" height="760" as="geometry" />
        </mxCell>
        <mxCell id="bg-route" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="6110" width="2940" height="650" as="geometry" />
        </mxCell>
        <mxCell id="bg-guardrails" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fed7aa;" vertex="1" parent="1">
          <mxGeometry x="40" y="6800" width="2940" height="620" as="geometry" />
        </mxCell>

        <!-- Stage labels -->
        <mxCell id="stage-entry" value="Entry and contract loading" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#1d4ed8;strokeColor=#1d4ed8;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-resolve" value="1. Resolve" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0f766e;strokeColor=#0f766e;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="850" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-read" value="2. Read" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#7c3aed;strokeColor=#7c3aed;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="1530" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-decide" value="3. Decide" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d97706;strokeColor=#d97706;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="2390" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-execute" value="4. Execute" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0284c7;strokeColor=#0284c7;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="3480" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-persist" value="5. Persist" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#16a34a;strokeColor=#16a34a;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="4440" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-validate" value="6. Validate and repair" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#9333ea;strokeColor=#9333ea;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="5330" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-route" value="7. Route and report" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#047857;strokeColor=#047857;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="6130" width="230" height="38" as="geometry" />
        </mxCell>
        <mxCell id="stage-guardrails" value="Always-on guardrails and glossary" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ea580c;strokeColor=#ea580c;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="6820" width="280" height="38" as="geometry" />
        </mxCell>

        <!-- Entry cards -->
        <mxCell id="entry-user-trigger" value="&lt;b&gt;User trigger&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;User enters &lt;code&gt;/blu-research-phase [phase]&lt;/code&gt;. Example: &lt;code&gt;/blu-research-phase 3&lt;/code&gt;. Plain English: produce or reuse planner-ready research for one Blueprint phase.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-root-router" value="&lt;b&gt;Optional root-router form&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;/blu research-phase&lt;/code&gt; first uses the root router. Plain English: route only if the live catalog says the target command is implemented, otherwise explain the blocker instead of guessing.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="705" width="360" height="62" as="geometry" />
        </mxCell>
        <mxCell id="entry-manifest" value="&lt;b&gt;Command manifest&lt;/b&gt;&lt;br&gt;&lt;code&gt;commands/blu-research-phase.toml&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: the host entrypoint stays thin. It names the skill, required MCP tools, command-local gates, external-source policy, checkpoint rules, and final response shape.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="540" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-skill" value="&lt;b&gt;Primary skill&lt;/b&gt;&lt;br&gt;&lt;code&gt;skills/blueprint-phase-discovery/SKILL.md&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: shared orchestration policy for discovery commands. For this command it loads only the research-phase command inputs and keeps sibling discovery flows out of scope.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="705" width="440" height="62" as="geometry" />
        </mxCell>
        <mxCell id="entry-visibility" value="&lt;b&gt;Long-running mutation posture&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Visible stages: Resolve, Read, Decide, Execute, Persist, Validate, Route. Keep resolved scope, active stage, pending gate, execution mode, and next safe action visible during non-trivial runs.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="540" width="410" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-helper-scope" value="&lt;b&gt;Session helpers are optional&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;ask_user&lt;/code&gt; handles gates. &lt;code&gt;update_topic&lt;/code&gt; and &lt;code&gt;write_todos&lt;/code&gt; may aid visibility on Gemini but never become Blueprint state.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="705" width="410" height="62" as="geometry" />
        </mxCell>
        <mxCell id="entry-contract" value="&lt;b&gt;Rich behavior authority&lt;/b&gt;&lt;br&gt;&lt;code&gt;skills/blueprint-phase-discovery/references/research-phase-runtime-contract.md&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: detailed rules for planner-grade evidence depth, topic strands, checkpoint ownership, optional agent use, validation repair, and safe routing.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="540" width="500" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-catalog" value="&lt;b&gt;Runtime catalog eligibility&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Internal contract: catalog row is &lt;code&gt;implemented&lt;/code&gt; only when the manifest, primary skill, and required MCP tools are present. Plain English: root routing exposes only complete command contracts.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="540" width="500" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-no-write" value="&lt;b&gt;No durable writes yet&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Entry only loads prompt contracts and decides whether this command is allowed. &lt;code&gt;XX-RESEARCH.md&lt;/code&gt;, the checkpoint, and &lt;code&gt;STATE.md&lt;/code&gt; are untouched until later stages.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="540" width="420" height="150" as="geometry" />
        </mxCell>

        <!-- Resolve cards -->
        <mxCell id="resolve-user-scope" value="&lt;b&gt;Resolve requested phase&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: use the user-supplied number when present. If omitted, let runtime infer from &lt;code&gt;STATE.md&lt;/code&gt; and roadmap rules. Do not pass folders, slugs, or filenames as phase inputs.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="925" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="resolve-skill-gate" value="&lt;b&gt;Command-local gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The first durable fact must be the resolved phase. If it cannot be resolved, the workflow stops with the precise reason and recovery guidance instead of drafting research from guesswork.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="925" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="resolve-no-agent" value="&lt;b&gt;No agent yet&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Resolve is deterministic state discovery. Optional research assistance is considered only after the phase, context, existing research, external policy, and contract are known.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="925" width="410" height="150" as="geometry" />
        </mxCell>
        <mxCell id="resolve-locate-call" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_locate&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_phase_locate&lt;/code&gt;&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhaseLocate(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Find the phase number, prefix, name, directory, milestone, and known phase artifacts.&lt;br&gt;&lt;b&gt;Typical input&lt;/b&gt;&lt;br&gt;&lt;code&gt;{ phase: 3 }&lt;/code&gt; or omit phase for inference." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="900" width="500" height="226" as="geometry" />
        </mxCell>
        <mxCell id="resolve-locate-internals" value="&lt;b&gt;Inside phase locate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;ensureRepoRoot&lt;/code&gt;: keep paths inside the repo.&lt;br&gt;&lt;code&gt;readRoadmap&lt;/code&gt;: parse &lt;code&gt;.blueprint/ROADMAP.md&lt;/code&gt;.&lt;br&gt;&lt;code&gt;resolveRequestedPhase&lt;/code&gt;: normalize numeric phase refs.&lt;br&gt;&lt;code&gt;findPhaseDirectory&lt;/code&gt;: find the matching phase folder.&lt;br&gt;&lt;code&gt;listPhaseArtifacts&lt;/code&gt;: list saved files under the phase directory.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="900" width="500" height="226" as="geometry" />
        </mxCell>
        <mxCell id="resolve-locate-output" value="&lt;b&gt;Locate output&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Returns &lt;code&gt;found&lt;/code&gt;, &lt;code&gt;phaseNumber&lt;/code&gt;, &lt;code&gt;phasePrefix&lt;/code&gt;, &lt;code&gt;phaseName&lt;/code&gt;, &lt;code&gt;phaseDir&lt;/code&gt;, &lt;code&gt;artifacts&lt;/code&gt;, &lt;code&gt;reason&lt;/code&gt;, &lt;code&gt;recovery&lt;/code&gt;, and &lt;code&gt;warnings&lt;/code&gt;. The returned phase path is authoritative.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="900" width="420" height="226" as="geometry" />
        </mxCell>
        <mxCell id="resolve-context-call" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_context&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_phase_context&lt;/code&gt;&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhaseContext(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Summarize the roadmap slice, project brief, requirement grounding, workflow posture, mapped codebase bundle, missing artifacts, and warnings for the selected phase." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="1170" width="500" height="214" as="geometry" />
        </mxCell>
        <mxCell id="resolve-context-internals" value="&lt;b&gt;Inside phase context&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Loads roadmap and &lt;code&gt;STATE.md&lt;/code&gt;, reuses &lt;code&gt;blueprint_phase_locate&lt;/code&gt;, reads mapped &lt;code&gt;.blueprint/codebase/&lt;/code&gt; summaries when present, computes context, research, and UI-spec expected paths, and warns when the phase lacks context or requirements.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="1170" width="500" height="214" as="geometry" />
        </mxCell>
        <mxCell id="resolve-context-output" value="&lt;b&gt;Resolved research scope&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The command now knows the phase goal, success criteria, requirement IDs, codebase summary availability, missing artifact list, external-source mirror, current blockers, and next action before reading artifact bodies.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="1170" width="420" height="214" as="geometry" />
        </mxCell>
        <mxCell id="resolve-stop" value="&lt;b&gt;Failure route from Resolve&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If roadmap is missing, the phase is absent, or the phase directory is ambiguous or missing, stop. Report &lt;code&gt;reason&lt;/code&gt; and &lt;code&gt;recovery&lt;/code&gt;. No artifact reads or writes follow.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1170" width="890" height="112" as="geometry" />
        </mxCell>

        <!-- Read cards -->
        <mxCell id="read-config-call" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_config_get&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_config_get&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Read effective config before any external verification decision. &lt;code&gt;research.external_sources&lt;/code&gt; is source of truth: &lt;code&gt;off&lt;/code&gt;, &lt;code&gt;ask&lt;/code&gt;, or &lt;code&gt;auto&lt;/code&gt;." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="1600" width="500" height="174" as="geometry" />
        </mxCell>
        <mxCell id="read-status-call" value="&lt;b&gt;Runtime FQN&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_research_status&lt;/code&gt;&lt;br&gt;&lt;b&gt;Tool&lt;/b&gt; &lt;code&gt;blueprint_phase_research_status&lt;/code&gt;&lt;br&gt;&lt;b&gt;Handler&lt;/b&gt; &lt;code&gt;blueprintPhaseResearchStatus(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;&lt;br&gt;Check whether context, research, and UI-spec artifacts exist and whether saved research is usable or needs repair." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="1805" width="500" height="204" as="geometry" />
        </mxCell>
        <mxCell id="read-artifact-context-call" value="&lt;b&gt;Mandatory artifact body read&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_phase_artifact_read&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_phase_artifact_read&lt;/code&gt;&lt;br&gt;Input: &lt;code&gt;{ phase: 3, artifact: &quot;context&quot; }&lt;/code&gt;&lt;br&gt;Plain English: load the real saved &lt;code&gt;XX-CONTEXT.md&lt;/code&gt; content that constrains research. Status booleans are not enough." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="2038" width="500" height="206" as="geometry" />
        </mxCell>
        <mxCell id="read-context-gate" value="&lt;b&gt;Missing context gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If the context read returns &lt;code&gt;found: false&lt;/code&gt;, stop and route to &lt;code&gt;/blu-discuss-phase phase&lt;/code&gt;. Plain English: research cannot replace discovery decisions.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="1600" width="360" height="146" as="geometry" />
        </mxCell>
        <mxCell id="read-existing-research" value="&lt;b&gt;Existing research body read&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Call &lt;code&gt;blueprint_phase_artifact_read&lt;/code&gt; with &lt;code&gt;artifact: &quot;research&quot;&lt;/code&gt; when research exists. Plain English: view, skip, update, and repair decisions must inspect the actual saved text, not just a path.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1600" width="440" height="146" as="geometry" />
        </mxCell>
        <mxCell id="read-checkpoint-call" value="&lt;b&gt;Checkpoint read&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_phase_checkpoint_get&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_phase_checkpoint_get&lt;/code&gt;&lt;br&gt;Input includes &lt;code&gt;expectedOwnerCommand: &quot;/blu-research-phase&quot;&lt;/code&gt; and &lt;code&gt;expectedMode: &quot;research&quot;&lt;/code&gt;.&lt;br&gt;Plain English: discover resumable in-progress research and avoid resuming someone else's checkpoint." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1986" width="440" height="156" as="geometry" />
        </mxCell>
        <mxCell id="read-state-catalog" value="&lt;b&gt;State and catalog reads&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;mcp_blueprint_blueprint_state_load&lt;/code&gt; reads current &lt;code&gt;STATE.md&lt;/code&gt; and derived status. &lt;code&gt;mcp_blueprint_blueprint_command_catalog&lt;/code&gt; reads implemented command truth for later routing. Plain English: route from live state, not assumptions.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1784" width="440" height="162" as="geometry" />
        </mxCell>
        <mxCell id="read-contract-call" value="&lt;b&gt;Canonical research contract read&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_artifact_contract_read&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_artifact_contract_read&lt;/code&gt;&lt;br&gt;Input: &lt;code&gt;{ artifactId: &quot;phase.research&quot; }&lt;/code&gt;&lt;br&gt;Plain English: fetch the MCP-owned heading order, locked markers, placeholder signals, freehand policy, notes, and &lt;code&gt;contract.authoringTemplate&lt;/code&gt; before drafting or revising." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="2012" width="410" height="216" as="geometry" />
        </mxCell>
        <mxCell id="read-status-internals" value="&lt;b&gt;Inside research status&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Calls phase context, evaluates context and UI-spec usability, reads &lt;code&gt;XX-RESEARCH.md&lt;/code&gt; when present, runs &lt;code&gt;validateResearchArtifactContent&lt;/code&gt;, records issues and warnings, and suggests repairs such as rerunning research or discuss-phase.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="1600" width="500" height="178" as="geometry" />
        </mxCell>
        <mxCell id="read-checkpoint-internals" value="&lt;b&gt;Inside checkpoint safety&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Parses the shared &lt;code&gt;XX-DISCUSS-CHECKPOINT.json&lt;/code&gt;, derives &lt;code&gt;ownerCommand&lt;/code&gt; and &lt;code&gt;resumeMeta.mode&lt;/code&gt;, reports legacy or ownership warnings, and sets &lt;code&gt;safeToResume&lt;/code&gt; only when the checkpoint belongs to this command and mode.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="1810" width="500" height="178" as="geometry" />
        </mxCell>
        <mxCell id="read-contract-output" value="&lt;b&gt;Contract output&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Required headings: Phase Requirements, Summary, Locked Decisions, User Constraints, Standard Stack, Installation, Alternatives, Architecture Patterns, Don't Hand-Roll, Anti-Patterns, State Of The Art, Pitfalls, Open Questions, Confidence Breakdown, Code Examples, Recommendations, Sources. Locked marker: &lt;code&gt;**Confidence:**&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="1600" width="420" height="262" as="geometry" />
        </mxCell>
        <mxCell id="read-scaffold-note" value="&lt;b&gt;Scaffold is exceptional&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;mcp_blueprint_blueprint_artifact_scaffold&lt;/code&gt; may seed a deliberate placeholder only if the user explicitly wants that before final research exists. Plain English: scaffold text is starter material, never completed research.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="1898" width="420" height="154" as="geometry" />
        </mxCell>
        <mxCell id="read-evidence-bundle" value="&lt;b&gt;Read-stage evidence bundle&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: by the end of Read, the command has phase scope, real context text, existing research text or absence, checkpoint posture, external-source policy, state, catalog, and the canonical template. Drafting can now be controlled instead of improvised.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="2084" width="420" height="160" as="geometry" />
        </mxCell>
        <mxCell id="read-user-gates" value="&lt;b&gt;Possible user-facing gates discovered&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Missing context, valid existing research choice, invalid research repair, safe checkpoint resume, foreign checkpoint warning, external source confirmation, overwrite permission, or validation blocker.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="1784" width="360" height="162" as="geometry" />
        </mxCell>
        <mxCell id="read-agent-still-waits" value="&lt;b&gt;Agent still waits&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;No optional researcher should run until the parent command can supply the resolved phase, saved context, codebase evidence, external evidence packet if any, existing research when relevant, and the canonical template.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="1600" width="410" height="176" as="geometry" />
        </mxCell>
        <mxCell id="read-progress-visibility" value="&lt;b&gt;Visibility recap&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Stage: Read. Pending gate: whichever read result now blocks progress. Execution mode: create, repair, update, resume, view, skip, or repo-only research candidate. Next safe action is provisional until Route reloads state.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="1810" width="410" height="166" as="geometry" />
        </mxCell>

        <!-- Decide cards -->
        <mxCell id="decide-existing-valid" value="&lt;b&gt;Existing research valid?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If &lt;code&gt;researchValid: true&lt;/code&gt;, ask one explicit &lt;code&gt;ask_user&lt;/code&gt; choice: view, skip, or update. View means show the saved artifact. Skip or reuse means no research write. Update is the overwrite gate.&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=10;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="110" y="2498" width="300" height="196" as="geometry" />
        </mxCell>
        <mxCell id="decide-invalid" value="&lt;b&gt;Existing research invalid?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Repair or update is the only successful path. Plain English: invalid saved research cannot be silently reused, skipped, viewed as complete, or written back unchanged as success.&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=10;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="110" y="2742" width="300" height="196" as="geometry" />
        </mxCell>
        <mxCell id="decide-create" value="&lt;b&gt;No research yet?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Create path. Plain English: research starts from the contract template and real context evidence, not from a blank outline or scaffold-only placeholder.&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=10;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="110" y="2986" width="300" height="154" as="geometry" />
        </mxCell>
        <mxCell id="decide-checkpoint" value="&lt;b&gt;Checkpoint branch&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If &lt;code&gt;safeToResume: true&lt;/code&gt;, resume by default unless the user discards it. If ownership or mode is foreign or unknown, warn and do not resume it. Never delete an unguarded shared checkpoint.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="2470" width="440" height="168" as="geometry" />
        </mxCell>
        <mxCell id="decide-external-policy" value="&lt;b&gt;External-source policy fork&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;off&lt;/code&gt;: repo-only; avoid implying live external checks ran.&lt;br&gt;&lt;code&gt;ask&lt;/code&gt;: stop for confirmation before official-doc or external verification.&lt;br&gt;&lt;code&gt;auto&lt;/code&gt;: allow official or supplied external checks only when repo evidence cannot settle the claim.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="2675" width="440" height="222" as="geometry" />
        </mxCell>
        <mxCell id="decide-overwrite" value="&lt;b&gt;Overwrite gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Choosing update on valid existing research is explicit overwrite permission. Repairing invalid existing research also requires an intentional update path. No default overwrite path exists.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="2934" width="440" height="142" as="geometry" />
        </mxCell>
        <mxCell id="decide-agent-fork" value="&lt;b&gt;Optional agent decision&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Use &lt;code&gt;blueprint-researcher&lt;/code&gt; only if the host exposes a suitable Blueprint research or code-analysis agent and isolated sidecar work materially helps one topic strand. Browser-only, web-search-only, shell-only, or generic agents are not substitutes.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;strokeWidth=2;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="2470" width="410" height="204" as="geometry" />
        </mxCell>
        <mxCell id="decide-agent-packet" value="&lt;b&gt;Parent-supplied agent packet&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Phase number and name, goal, success criteria, requirement IDs, saved context text, codebase evidence, existing research when revising, external evidence packet if already approved or supplied, contract template, topic strand, source rules, confidence expectations.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="2714" width="410" height="200" as="geometry" />
        </mxCell>
        <mxCell id="decide-fallback" value="&lt;b&gt;No-subagent fallback&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The parent command still completes quality research by handling one topic strand at a time, compressing carry-forward context, reading only needed repo files or saved Blueprint docs, and checkpointing if work pauses or remains inconclusive.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="2954" width="410" height="160" as="geometry" />
        </mxCell>
        <mxCell id="decide-parent-owns" value="&lt;b&gt;Parent owns synthesis and writes&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Even when an agent is used, the parent command owns user gates, external approval, normalization, checkpointing, final MCP persistence, state update, command catalog routing, and final user response.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="2470" width="500" height="168" as="geometry" />
        </mxCell>
        <mxCell id="decide-evidence-boundary" value="&lt;b&gt;Evidence boundary decision&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Repo evidence controls phase boundary. Official or supplied external references may support current ecosystem claims only when allowed. Inference must be labeled, and unresolved conflicts lower confidence or become open questions.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="2675" width="500" height="178" as="geometry" />
        </mxCell>
        <mxCell id="decide-stop-pause" value="&lt;b&gt;Stop or pause branch&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If evidence is broad, contradictory, blocked on approval, or not yet planner-grade, checkpoint verified and unresolved strands instead of pretending the artifact is final.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="2890" width="500" height="144" as="geometry" />
        </mxCell>
        <mxCell id="decide-outcomes" value="&lt;b&gt;Decision-stage outcomes&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Possible paths: view existing valid research, skip or reuse it, update valid research, repair invalid research, create new research, resume a research checkpoint, discard checkpoint by explicit user intent, run repo-only, run repo-plus-approved external verification, or checkpoint blockers.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="2470" width="420" height="248" as="geometry" />
        </mxCell>
        <mxCell id="decide-no-writes" value="&lt;b&gt;Still no final artifact write&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Decide may ask, route, or choose a path. It does not hand-edit &lt;code&gt;.blueprint/&lt;/code&gt;. Durable checkpoint writes happen only when pausing or inconclusive. Final research writes wait until a normalized draft is ready.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="2755" width="420" height="176" as="geometry" />
        </mxCell>
        <mxCell id="decide-mcp-read-only" value="&lt;b&gt;MCP posture in Decide&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Most calls are already-completed reads. The only possible persistence in this stage is a deliberate checkpoint through &lt;code&gt;blueprint_phase_checkpoint_put&lt;/code&gt; if the run cannot safely finish now.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="2470" width="500" height="176" as="geometry" />
        </mxCell>
        <mxCell id="decide-ask-user" value="&lt;b&gt;Structured user gates&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Prefer &lt;code&gt;ask_user&lt;/code&gt; for valid-research view, skip, update choice; external-source confirmation when policy is ask; resume-versus-discard when ambiguity exists; and overwrite confirmation if the user's intent is unclear.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="3180" width="830" height="116" as="geometry" />
        </mxCell>

        <!-- Execute cards -->
        <mxCell id="execute-carry-forward" value="&lt;b&gt;Build carry-forward packet&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: collect everything needed to research without losing the phase boundary: roadmap goal, success criteria, requirement mapping, context decisions, user constraints, codebase summaries, existing research posture, approved external evidence, open questions, and current confidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="3568" width="360" height="190" as="geometry" />
        </mxCell>
        <mxCell id="execute-topic-loop" value="&lt;b&gt;Topic-strand loop&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Research one strand at a time: stack and versions, architecture patterns, dependency or runtime availability, validation and testing impact, risk and pitfalls, state of the art, source provenance, and recommendations. Compress each completed strand into the carry-forward packet.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="3568" width="440" height="190" as="geometry" />
        </mxCell>
        <mxCell id="execute-agent-path" value="&lt;b&gt;Capability-gated agent path&lt;/b&gt;&lt;br&gt;&lt;code&gt;blueprint-researcher&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: a bounded read-only sidecar can draft a section or analyze one evidence question. It returns populated content plus warnings. It does not fetch official docs, mutate files, checkpoint, update state, route, or replace parent synthesis.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;strokeWidth=2;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="3568" width="410" height="216" as="geometry" />
        </mxCell>
        <mxCell id="execute-fallback-path" value="&lt;b&gt;Single-agent fallback path&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: if no suitable agent is available, the parent session reads the needed repo files or saved Blueprint artifacts for each strand, updates the draft section-by-section, and preserves the same quality bar.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="3818" width="410" height="158" as="geometry" />
        </mxCell>
        <mxCell id="execute-no-mcp-write" value="&lt;b&gt;No final MCP write during research reads&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;MCP read results control the draft. Repo file reads and optional external checks support analysis. The final artifact is not persisted until the draft is normalized and self-checked against the canonical contract.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="3568" width="500" height="178" as="geometry" />
        </mxCell>
        <mxCell id="execute-external-packet" value="&lt;b&gt;External evidence packet shape&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;When allowed and needed, each outside reference must carry source title, source date, URL or supplied-reference identity, excerpt or claim, and evidence class such as official reference or supplied reference. Plain English: external claims stay traceable and separate from repo behavior.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="3778" width="500" height="188" as="geometry" />
        </mxCell>
        <mxCell id="execute-quality-rules" value="&lt;b&gt;Planner-grade content rules&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Every section must be phase-specific. Requirements map to research support. Recommendations are prescriptive. Don't Hand-Roll and Anti-Patterns name real implementation guidance. Pitfalls explain prevention or validation. Sources separate repo evidence, official or supplied references, and inference.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="3568" width="500" height="216" as="geometry" />
        </mxCell>
        <mxCell id="execute-uncertainty" value="&lt;b&gt;Uncertainty handling&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If evidence conflicts or cannot support a safe recommendation, lower confidence, preserve the conflict in Open Questions, identify the needed confirmation, and checkpoint if the uncertainty blocks planner-grade guidance.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="3818" width="500" height="158" as="geometry" />
        </mxCell>
        <mxCell id="execute-draft-output" value="&lt;b&gt;Draft output before persistence&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;A normalized, populated &lt;code&gt;phase.research&lt;/code&gt; body or a checkpoint-worthy partial state. The draft includes confidence, requirements table, sources, state-of-the-art context, examples or justified omission, and concrete next planning recommendations.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="3568" width="420" height="216" as="geometry" />
        </mxCell>
        <mxCell id="execute-progress" value="&lt;b&gt;Progress visibility during long runs&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;When helpers exist, &lt;code&gt;update_topic&lt;/code&gt; names the active strand and &lt;code&gt;write_todos&lt;/code&gt; lists strand progress. When helpers do not exist, concise recaps plus MCP-backed checkpoints preserve legibility.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="3798" width="840" height="124" as="geometry" />
        </mxCell>
        <mxCell id="execute-section-map" value="&lt;b&gt;Section map produced by Execute&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Phase Requirements, Summary, Locked Decisions From Context, User Constraints, Standard Stack, Installation And Setup, Alternatives Considered, Architecture Patterns, Don't Hand-Roll, Anti-Patterns, State Of The Art, Common Pitfalls, Open Questions, Confidence Breakdown, Code Examples, Recommendations, Sources.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="4050" width="1950" height="116" as="geometry" />
        </mxCell>

        <!-- Persist cards -->
        <mxCell id="persist-template" value="&lt;b&gt;Normalize from authoring template&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: the final body starts from &lt;code&gt;contract.authoringTemplate&lt;/code&gt;. Required headings and &lt;code&gt;**Confidence:**&lt;/code&gt; stay unchanged. Angle-bracket placeholders and scaffold footer text are removed before persistence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="4528" width="360" height="178" as="geometry" />
        </mxCell>
        <mxCell id="persist-checkpoint-put" value="&lt;b&gt;Checkpoint write path for pause or inconclusive research&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_phase_checkpoint_put&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_phase_checkpoint_put&lt;/code&gt;&lt;br&gt;Handler: &lt;code&gt;blueprintPhaseCheckpointPut(args)&lt;/code&gt;&lt;br&gt;Plain English: persist resumable strand state when research cannot finish safely now." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="4528" width="500" height="196" as="geometry" />
        </mxCell>
        <mxCell id="persist-checkpoint-shape" value="&lt;b&gt;Checkpoint JSON shape&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Required fields: &lt;code&gt;ownerCommand&lt;/code&gt;, &lt;code&gt;completedAreas&lt;/code&gt;, &lt;code&gt;remainingAreas&lt;/code&gt;, &lt;code&gt;decisions&lt;/code&gt;, &lt;code&gt;deferredIdeas&lt;/code&gt;, &lt;code&gt;canonicalReferences&lt;/code&gt;, and &lt;code&gt;resumeMeta&lt;/code&gt;. For research: &lt;code&gt;ownerCommand: &quot;/blu-research-phase&quot;&lt;/code&gt; and &lt;code&gt;resumeMeta.mode: &quot;research&quot;&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="4528" width="500" height="196" as="geometry" />
        </mxCell>
        <mxCell id="persist-checkpoint-output" value="&lt;b&gt;Checkpoint artifact&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Path is tool-owned and shared: &lt;code&gt;.blueprint/phases/.../XX-DISCUSS-CHECKPOINT.json&lt;/code&gt;. Plain English: the filename is legacy-compatible; ownership is declared inside the JSON body.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="4528" width="420" height="196" as="geometry" />
        </mxCell>
        <mxCell id="persist-artifact-write" value="&lt;b&gt;Final research write path&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_phase_artifact_write&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_phase_artifact_write&lt;/code&gt;&lt;br&gt;Handler: &lt;code&gt;blueprintPhaseArtifactWrite(args)&lt;/code&gt;&lt;br&gt;Input: numeric &lt;code&gt;phase&lt;/code&gt;, &lt;code&gt;artifact: &quot;research&quot;&lt;/code&gt;, full markdown &lt;code&gt;content&lt;/code&gt;, and &lt;code&gt;overwrite: true&lt;/code&gt; only after the appropriate gate.&lt;br&gt;Plain English: save substantive phase research through the MCP-owned path, never by hand-building a filename.&lt;br&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="4760" width="500" height="260" as="geometry" />
        </mxCell>
        <mxCell id="persist-write-internals" value="&lt;b&gt;Inside artifact write&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;resolveLocatedPhaseForMutation&lt;/code&gt; resolves phase safely.&lt;br&gt;&lt;code&gt;artifactPathFor&lt;/code&gt; derives the tool-owned path.&lt;br&gt;&lt;code&gt;normalizeTextContent&lt;/code&gt; prepares markdown.&lt;br&gt;&lt;code&gt;validatePhaseArtifactContent&lt;/code&gt; delegates research checks to &lt;code&gt;validateResearchArtifactContent&lt;/code&gt;.&lt;br&gt;&lt;code&gt;writeTextFile&lt;/code&gt; persists only after validation and overwrite rules allow it.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="4760" width="500" height="260" as="geometry" />
        </mxCell>
        <mxCell id="persist-write-output" value="&lt;b&gt;Write result&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Returns authoritative &lt;code&gt;path&lt;/code&gt;, &lt;code&gt;written&lt;/code&gt;, &lt;code&gt;created&lt;/code&gt;, &lt;code&gt;overwritten&lt;/code&gt;, &lt;code&gt;status&lt;/code&gt;, &lt;code&gt;validation&lt;/code&gt;, and warnings. Status can be created, updated, reused, or invalid.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="4760" width="420" height="260" as="geometry" />
        </mxCell>
        <mxCell id="persist-reuse-rules" value="&lt;b&gt;Reuse and replacement rules&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Identical valid content returns &lt;code&gt;status: &quot;reused&quot;&lt;/code&gt; and no write. Existing scaffold can be replaced by substantive content with a warning. Existing valid content requires explicit overwrite. Existing invalid unchanged content returns invalid, not success.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="4528" width="440" height="196" as="geometry" />
        </mxCell>
        <mxCell id="persist-delete-checkpoint" value="&lt;b&gt;Cleanup after final success&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_phase_checkpoint_delete&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_phase_checkpoint_delete&lt;/code&gt;&lt;br&gt;Plain English: delete only this command's research-owned checkpoint after a successful final research write. Pass expected owner and mode so foreign shared checkpoints are protected." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="4760" width="440" height="176" as="geometry" />
        </mxCell>
        <mxCell id="persist-scaffold-note" value="&lt;b&gt;Optional scaffold path&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;blueprint_artifact_scaffold&lt;/code&gt; may create a placeholder before final research only by deliberate user intent. The command must not present scaffold-only content as completed research.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="4740" width="360" height="156" as="geometry" />
        </mxCell>
        <mxCell id="persist-paths" value="&lt;b&gt;Allowed persistent outputs in this command&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Final research: &lt;code&gt;.blueprint/phases/phase-slug/XX-RESEARCH.md&lt;/code&gt;.&lt;br&gt;Continuation state: shared &lt;code&gt;XX-DISCUSS-CHECKPOINT.json&lt;/code&gt; only when research is paused or inconclusive.&lt;br&gt;State sync later: &lt;code&gt;.blueprint/STATE.md&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="5038" width="420" height="154" as="geometry" />
        </mxCell>

        <!-- Validate cards -->
        <mxCell id="validate-checks" value="&lt;b&gt;Strict research validation&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;validateResearchArtifactContent(content)&lt;/code&gt; checks H1 ending in &lt;code&gt;- Research&lt;/code&gt;, no scaffold placeholders, &lt;code&gt;**Confidence:** LOW, MEDIUM, or HIGH, every required section, substantive content, at least one Phase Requirements row, at least one Recommendations bullet, and at least one source bullet with a URL, repo path, or cited file.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;strokeWidth=2;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="5418" width="500" height="248" as="geometry" />
        </mxCell>
        <mxCell id="validate-freshness" value="&lt;b&gt;State Of The Art provenance guidance&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The runtime contract suggests dates or unchecked markers for freshness-sensitive external claims. MCP validation does not require either marker.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="5702" width="500" height="148" as="geometry" />
        </mxCell>
        <mxCell id="validate-write-result" value="&lt;b&gt;Write returned invalid?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If &lt;code&gt;status: &quot;invalid&quot;&lt;/code&gt;, use returned &lt;code&gt;validation.issues&lt;/code&gt;, &lt;code&gt;warnings&lt;/code&gt;, and &lt;code&gt;suggestedRepairs&lt;/code&gt; to repair the same normalized draft and retry if safe. Do not count invalid output as complete.&lt;/span&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;strokeWidth=2;fontColor=#7c2d12;spacing=10;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="5462" width="320" height="206" as="geometry" />
        </mxCell>
        <mxCell id="validate-repair-loop" value="&lt;b&gt;Repair loop&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: fix missing headings, placeholders, weak sections, source evidence, confidence marker, freshness marker, or requirement rows, then call &lt;code&gt;blueprint_phase_artifact_write&lt;/code&gt; again. Keep overwrite intent from the earlier gate.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="5418" width="440" height="186" as="geometry" />
        </mxCell>
        <mxCell id="validate-checkpoint-blocker" value="&lt;b&gt;Cannot repair safely?&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Persist or refresh a research-owned checkpoint with exact blockers and unresolved topics. Plain English: preserve the work and name the next safe continuation instead of fabricating certainty.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="5640" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="validate-mcp-calls" value="&lt;b&gt;Validation uses the same MCP write path&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;There is no separate manual validator write. The command revises the markdown body and retries through &lt;code&gt;mcp_blueprint_blueprint_phase_artifact_write&lt;/code&gt; in strict mode unless the command intentionally owns a warned save exception.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="5418" width="500" height="186" as="geometry" />
        </mxCell>
        <mxCell id="validate-post-status" value="&lt;b&gt;Validated output states&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Complete: valid created or updated research, or valid non-writing view, skip, or reuse path. Paused: checkpoint saved and final artifact not claimed. Blocked: exact validation or evidence blocker reported.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="5418" width="420" height="186" as="geometry" />
        </mxCell>
        <mxCell id="validate-warning" value="&lt;b&gt;Non-blocking warning example&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The validator warns when Code Examples lacks a fenced example and examples would add value. Plain English: some issues guide quality without blocking persistence; hard schema, source, placeholder, and freshness failures block strict completion.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="5640" width="420" height="150" as="geometry" />
        </mxCell>
        <mxCell id="validate-success-cleanup" value="&lt;b&gt;After final valid write&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Delete stale research-owned checkpoint with &lt;code&gt;expectedOwnerCommand&lt;/code&gt; and &lt;code&gt;expectedMode&lt;/code&gt;. Plain English: once final research is safely saved, old resumability state should not keep steering future runs.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="5640" width="500" height="150" as="geometry" />
        </mxCell>

        <!-- Route cards -->
        <mxCell id="route-state-update" value="&lt;b&gt;State sync after success or valid reuse&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_state_update&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_state_update&lt;/code&gt;&lt;br&gt;Handler: &lt;code&gt;blueprintStateUpdate(args)&lt;/code&gt;&lt;br&gt;Input uses &lt;code&gt;base: &quot;synced&quot;&lt;/code&gt;.&lt;br&gt;Plain English: recompute state from actual artifacts and patch command metadata so &lt;code&gt;STATE.md&lt;/code&gt; reflects the research outcome." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="6218" width="500" height="226" as="geometry" />
        </mxCell>
        <mxCell id="route-state-internals" value="&lt;b&gt;Inside state update and load&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;buildSyncedState&lt;/code&gt; inspects the current phase artifacts and validates research. &lt;code&gt;deriveNextAction&lt;/code&gt; recommends discuss, research repair, UI contract, plan, execute, validate, or progress based on readiness and implemented command availability. &lt;code&gt;writeTextFile&lt;/code&gt; rewrites &lt;code&gt;STATE.md&lt;/code&gt; deterministically.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1950" y="6218" width="500" height="226" as="geometry" />
        </mxCell>
        <mxCell id="route-state-load" value="&lt;b&gt;Reload refreshed state&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_state_load&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_state_load&lt;/code&gt;&lt;br&gt;Plain English: get final &lt;code&gt;derivedStatus.nextAction&lt;/code&gt; after the state file was synced. Do not assume the update response itself is the final route." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1410" y="6472" width="500" height="148" as="geometry" />
        </mxCell>
        <mxCell id="route-catalog" value="&lt;b&gt;Catalog-gated recommendation&lt;/b&gt;&lt;br&gt;Runtime FQN: &lt;code&gt;mcp_blueprint_blueprint_command_catalog&lt;/code&gt;&lt;br&gt;Tool: &lt;code&gt;blueprint_command_catalog&lt;/code&gt;&lt;br&gt;Plain English: recommend only commands whose live catalog entry has &lt;code&gt;implemented: true&lt;/code&gt;. Planned, blocked, or repairing commands stay non-routable." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="6218" width="440" height="186" as="geometry" />
        </mxCell>
        <mxCell id="route-next-actions" value="&lt;b&gt;Common next safe actions&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Missing context: &lt;code&gt;/blu-discuss-phase phase&lt;/code&gt;.&lt;br&gt;Valid research and UI enabled but no UI spec: &lt;code&gt;/blu-ui-phase phase&lt;/code&gt;.&lt;br&gt;Context, research, and UI readiness satisfied with no plans: &lt;code&gt;/blu-plan-phase phase&lt;/code&gt;.&lt;br&gt;Unclear or blocked: &lt;code&gt;/blu-progress&lt;/code&gt; or exact blocker.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;strokeWidth=2;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="6218" width="420" height="226" as="geometry" />
        </mxCell>
        <mxCell id="route-final-response" value="&lt;b&gt;Final user response&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Keep it concise: phase, outcome type such as viewed, reused, created, updated, repaired, or checkpointed, saved path when applicable, validation warnings or blockers, and next safe implemented action.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="6218" width="360" height="186" as="geometry" />
        </mxCell>
        <mxCell id="route-artifacts" value="&lt;b&gt;Final durable state&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Either a validated &lt;code&gt;XX-RESEARCH.md&lt;/code&gt; exists or a research-owned checkpoint records why final research is not safe yet. &lt;code&gt;STATE.md&lt;/code&gt; is synced on successful write or valid non-writing reuse path.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2490" y="6472" width="420" height="148" as="geometry" />
        </mxCell>
        <mxCell id="route-no-planned" value="&lt;b&gt;Routing safety invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;/blu, /blu-help, /blu-progress, and this command's final guidance must not recommend planned-only commands. Plain English: docs can mention future work, but user routing only exposes live implemented runtime contracts.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="6472" width="890" height="148" as="geometry" />
        </mxCell>

        <!-- Guardrails and glossary cards -->
        <mxCell id="guardrail-boundaries" value="&lt;b&gt;Persistence boundaries&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Allowed writes: selected phase research artifact, selected phase shared checkpoint, and &lt;code&gt;.blueprint/STATE.md&lt;/code&gt;. All durable writes go through MCP tools. Plain English: no raw hand-edits to &lt;code&gt;.blueprint/&lt;/code&gt; and no scripts as persistence substitutes.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="6900" width="560" height="154" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-inputs" value="&lt;b&gt;Tool input discipline&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Pass numeric phase refs only. Use returned &lt;code&gt;phaseNumber&lt;/code&gt;, &lt;code&gt;phasePrefix&lt;/code&gt;, &lt;code&gt;phaseDir&lt;/code&gt;, and &lt;code&gt;path&lt;/code&gt; as authoritative. Plain English: do not invent filenames or pass slugs back into phase-write tools.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="6900" width="560" height="154" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-sources" value="&lt;b&gt;Provenance labels&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Use labels such as Repo evidence, Official reference, Supplied reference, and Inference. Plain English: a planner should see exactly why each recommendation is trusted and where the evidence came from.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1280" y="6900" width="560" height="154" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-hooks" value="&lt;b&gt;Hook involvement&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;read-before-edit&lt;/code&gt; and the &lt;code&gt;.blueprint&lt;/code&gt; write guard are advisory guardrails. Plain English: they can warn about unsafe editing patterns, but they do not own state transitions or replace MCP validation.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1880" y="6900" width="500" height="154" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-complete" value="&lt;b&gt;Completion definition&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Complete means phase and paths resolved through MCP, valid or explicitly chosen existing-research path handled, final artifact normalized to contract, strict write validation passed or blocker checkpointed, stale research checkpoint cleaned up after success, state synced, and next action gated by implemented command catalog.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#fb923c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2420" y="6900" width="490" height="154" as="geometry" />
        </mxCell>
        <mxCell id="guardrail-tool-list" value="&lt;b&gt;Complete allowed MCP set for /blu-research-phase&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;blueprint_phase_locate&lt;/code&gt;, &lt;code&gt;blueprint_phase_context&lt;/code&gt;, &lt;code&gt;blueprint_phase_research_status&lt;/code&gt;, &lt;code&gt;blueprint_phase_artifact_read&lt;/code&gt;, &lt;code&gt;blueprint_phase_artifact_write&lt;/code&gt;, &lt;code&gt;blueprint_phase_checkpoint_get&lt;/code&gt;, &lt;code&gt;blueprint_phase_checkpoint_put&lt;/code&gt;, &lt;code&gt;blueprint_phase_checkpoint_delete&lt;/code&gt;, &lt;code&gt;blueprint_artifact_contract_read&lt;/code&gt;, &lt;code&gt;blueprint_artifact_scaffold&lt;/code&gt;, &lt;code&gt;blueprint_config_get&lt;/code&gt;, &lt;code&gt;blueprint_state_load&lt;/code&gt;, &lt;code&gt;blueprint_command_catalog&lt;/code&gt;, &lt;code&gt;blueprint_state_update&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="7090" width="2830" height="154" as="geometry" />
        </mxCell>

        <!-- Primary flow arrows -->
        <mxCell id="edge-entry-resolve" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="entry-no-write" target="resolve-user-scope">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-resolve-read" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="resolve-context-output" target="read-context-gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-read-decide" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="read-evidence-bundle" target="decide-existing-valid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-decide-execute" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="decide-outcomes" target="execute-carry-forward">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-execute-persist" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="execute-draft-output" target="persist-template">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-persist-validate" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="persist-write-output" target="validate-write-result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-validate-route" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="validate-post-status" target="route-final-response">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-route-guardrails" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;strokeWidth=3;" edge="1" parent="1" source="route-artifacts" target="guardrail-complete">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Selected cross-lane arrows -->
        <mxCell id="edge-locate-internals" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="resolve-locate-call" target="resolve-locate-internals">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-locate-output" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="resolve-locate-internals" target="resolve-locate-output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-status-internals" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="read-status-call" target="read-status-internals">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-contract-output" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="read-contract-call" target="read-contract-output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-agent-fallback" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#d97706;strokeWidth=2;dashed=1;" edge="1" parent="1" source="decide-agent-fork" target="execute-agent-path">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-write-internals" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="persist-artifact-write" target="persist-write-internals">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-write-output" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="persist-write-internals" target="persist-write-output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-invalid-repair" value="repair and retry" style="endArrow=block;html=1;rounded=0;strokeColor=#fb923c;strokeWidth=2;dashed=1;fontColor=#7c2d12;" edge="1" parent="1" source="validate-write-result" target="validate-repair-loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-state-internals" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="route-state-update" target="route-state-internals">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-state-next" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#64748b;strokeWidth=2;" edge="1" parent="1" source="route-state-internals" target="route-next-actions">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
