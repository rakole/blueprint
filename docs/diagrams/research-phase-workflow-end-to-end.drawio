        <mxCell id="col-mcp" value="Blueprint MCP tool calls" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontColor=#3b0764;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="1410" y="380" width="500" height="56" as="geometry" />
        </mxCell>
        <mxCell id="col-runtime" value="Runtime internals and validation" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="1950" y="380" width="500" height="56" as="geometry" />
        </mxCell>
        <mxCell id="col-artifacts" value="Artifacts, output, and routing" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="2490" y="380" width="420" height="56" as="geometry" />
        </mxCell>

        <!-- Stage backgrounds -->
        <mxCell id="bg-entry" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="2940" height="330" as="geometry" />
