        <mxCell id="bg-execute" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="3460" width="2940" height="920" as="geometry" />
        </mxCell>
        <mxCell id="bg-persist" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="4420" width="2940" height="850" as="geometry" />
