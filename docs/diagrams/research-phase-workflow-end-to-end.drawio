<mxfile host="app.diagrams.net" modified="2026-04-28T00:00:00.000Z" agent="codex" version="24.7.8">
  <diagram id="research-phase-workflow-end-to-end" name="research-phase workflow end-to-end">
    <mxGraphModel dx="3020" dy="7480" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3020" pageHeight="7480" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Canvas -->
        <mxCell id="canvas" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3020" height="7480" as="geometry" />
        </mxCell>

        <!-- Title and legend -->
        <mxCell id="title" value="&lt;div style=&quot;font-size:32px;font-weight:700;&quot;&gt;/blu-research-phase end-to-end workflow&lt;/div&gt;&lt;div style=&quot;font-size:15px;margin-top:8px;&quot;&gt;Presentation map of what happens from the user trigger through command routing, discovery contract loading, phase and artifact reads, topic-strand research, MCP-owned persistence, validation repair, state sync, and final next-action routing. Internal names are paired with plain-English explanations in each step.&lt;/div&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0f172a;gradientColor=#1e293b;strokeColor=#0f172a;fontColor=#ffffff;align=center;verticalAlign=middle;shadow=1;spacing=18;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="2940" height="130" as="geometry" />
        </mxCell>
        <mxCell id="legend-kind" value="&lt;b&gt;Diagram type: swimlane activity map&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Read left to right inside each stage, then follow the blue arrows down. This layout favors explanation depth over compactness for presentation walkthroughs.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#0f172a;spacing=14;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="610" height="134" as="geometry" />
        </mxCell>
        <mxCell id="legend-color" value="&lt;b&gt;Color key&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Blue: user and host. Gray: command or skill contract. Yellow: optional session helpers or agents. Purple: MCP tool calls. Cyan: runtime internals. Green: files, state, and outputs. Orange: gates, blockers, or decisions.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=14;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="190" width="620" height="134" as="geometry" />
        </mxCell>
        <mxCell id="legend-name-pattern" value="&lt;b&gt;Name pattern used below&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Runtime FQN&lt;/b&gt;: &lt;code&gt;mcp_blueprint_blueprint_phase_locate&lt;/code&gt;&lt;br&gt;&lt;b&gt;Registered MCP tool&lt;/b&gt;: &lt;code&gt;blueprint_phase_locate&lt;/code&gt;&lt;br&gt;&lt;b&gt;TypeScript handler&lt;/b&gt;: &lt;code&gt;blueprintPhaseLocate(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;: find the phase and its artifact folder safely.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1350" y="190" width="720" height="134" as="geometry" />
        </mxCell>
        <mxCell id="legend-invariant" value="&lt;b&gt;Core invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The command and skill own user-facing orchestration. MCP tools own durable reads and writes. &lt;code&gt;.blueprint/&lt;/code&gt; is runtime state. &lt;code&gt;XX-RESEARCH.md&lt;/code&gt; is not complete unless strict validation passes or the unresolved work is checkpointed honestly.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2110" y="190" width="870" height="134" as="geometry" />
        </mxCell>

        <!-- Column headers -->
        <mxCell id="col-user" value="User and Gemini host" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="360" height="56" as="geometry" />
        </mxCell>
        <mxCell id="col-skill" value="Command manifest and skill" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontColor=#0f172a;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="480" y="380" width="440" height="56" as="geometry" />
        </mxCell>
        <mxCell id="col-agent" value="Session helpers and optional agent" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="960" y="380" width="410" height="56" as="geometry" />
