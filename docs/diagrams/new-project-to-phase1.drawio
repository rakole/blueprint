        </mxCell>
        <mxCell id="gate-discuss" value="&lt;b&gt;Gray areas gate&lt;/b&gt;&lt;br&gt;If a decision changes outcome, capture it before plan generation." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="450" y="720" width="200" height="92" as="geometry" />
        </mxCell>
        <mxCell id="gate-depth" value="&lt;b&gt;Optional fork&lt;/b&gt;&lt;br&gt;Research unclear risks; write UI-SPEC only for UI-heavy work." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="685" y="720" width="200" height="92" as="geometry" />
        </mxCell>
        <mxCell id="gate-plan" value="&lt;b&gt;Plan reuse gate&lt;/b&gt;&lt;br&gt;If plans exist, choose reuse, revise, or replace before writing." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="920" y="720" width="200" height="92" as="geometry" />
        </mxCell>
        <mxCell id="gate-execute" value="&lt;b&gt;Recovery loop&lt;/b&gt;&lt;br&gt;PARTIAL or BLOCKED summaries route back to plan or execution." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="1155" y="720" width="200" height="92" as="geometry" />
        </mxCell>
        <mxCell id="gate-validate" value="&lt;b&gt;Ready-for-UAT gate&lt;/b&gt;&lt;br&gt;Verification must be evidence-based before verify-work can close Phase 1." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="1390" y="720" width="200" height="92" as="geometry" />
        </mxCell>
        <mxCell id="gate-close" value="&lt;b&gt;Next-action gate&lt;/b&gt;&lt;br&gt;Progress guidance points to Phase 2 discovery or the next safe repair." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="1625" y="720" width="200" height="92" as="geometry" />
        </mxCell>

        <!-- Conclusion area -->
        <mxCell id="closeout-main" value="&lt;div style=&quot;font-size:22px;font-weight:700;&quot;&gt;Phase 1 complete&lt;/div&gt;&lt;div style=&quot;font-size:13px;margin-top:8px;&quot;&gt;The roadmap marks Phase 1 complete only after validated summaries, verification evidence, and UAT evidence agree. The next phase begins with a durable record of intent, decisions, implementation results, and residual risk.&lt;/div&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#047857;gradientColor=#059669;strokeColor=#047857;fontColor=#ffffff;align=center;verticalAlign=middle;shadow=1;spacing=16;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="450" y="918" width="670" height="118" as="geometry" />
        </mxCell>
        <mxCell id="closeout-evidence" value="&lt;b&gt;Review packet at close&lt;/b&gt;&lt;br&gt;PROJECT / REQUIREMENTS / ROADMAP&lt;br&gt;CONTEXT / DISCUSSION / optional RESEARCH and UI-SPEC&lt;br&gt;PLAN / SUMMARY / VERIFICATION / UAT" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1155" y="918" width="435" height="118" as="geometry" />
        </mxCell>
        <mxCell id="closeout-brownfield" value="&lt;b&gt;Brownfield detour&lt;/b&gt;&lt;br&gt;If /blu-new-project detects an unmapped existing repo, the safe route is /blu-map-codebase before Phase 1 discovery proceeds." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#f59e0b;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="215" y="918" width="200" height="118" as="geometry" />
        </mxCell>
        <mxCell id="closeout-principles" value="&lt;b&gt;Why this holds together&lt;/b&gt;&lt;br&gt;Commands stay thin&lt;br&gt;MCP owns deterministic state&lt;br&gt;.blueprint/ remains the source of truth&lt;br&gt;Uncertainty is called out instead of hidden" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1625" y="918" width="200" height="118" as="geometry" />
        </mxCell>

