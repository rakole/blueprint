        <mxCell id="art-discuss" value="&lt;b&gt;01-CONTEXT.md&lt;/b&gt;&lt;br&gt;01-DISCUSSION-LOG.md&lt;br&gt;optional checkpoint JSON&lt;br&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Phase goals become concrete before planning.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
