        <!-- Gate cards -->
        <mxCell id="gate-new-project" value="&lt;b&gt;Routing safety&lt;/b&gt;&lt;br&gt;Root /blu, help, and progress expose only implemented catalog entries." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
