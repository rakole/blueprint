        <!-- Artifact cards -->
        <mxCell id="art-new-project" value="&lt;b&gt;.blueprint/ root&lt;/b&gt;&lt;br&gt;PROJECT.md&lt;br&gt;REQUIREMENTS.md&lt;br&gt;ROADMAP.md&lt;br&gt;STATE.md&lt;br&gt;config.json" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
