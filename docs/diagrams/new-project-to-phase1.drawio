        <mxCell id="art-depth" value="&lt;b&gt;01-RESEARCH.md&lt;/b&gt;&lt;br&gt;01-UI-SPEC.md&lt;br&gt;or explicit skip rationale&lt;br&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Optional artifacts remove uncertainty before plans harden.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=10;fontSize=12;fontFamily=Inter;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="685" y="530" width="200" height="126" as="geometry" />
        </mxCell>
        <mxCell id="art-plan" value="&lt;b&gt;01-01-PLAN.md&lt;/b&gt;&lt;br&gt;01-02-PLAN.md as needed&lt;br&gt;STATE.md updated&lt;br&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Plan set names work, dependencies, UAT, and risks.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="920" y="530" width="200" height="126" as="geometry" />
        </mxCell>
        <mxCell id="art-execute" value="&lt;b&gt;01-01-SUMMARY.md&lt;/b&gt;&lt;br&gt;more summaries as needed&lt;br&gt;STATE.md updated&lt;br&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;COMPLETED closes a plan; PARTIAL/BLOCKED stays visible.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#052e16;spacing=10;fontSize=12;fontFamily=Inter;" vertex="1" parent="1">
