        <mxCell id="bg-decide-label" value="3. Decide gates and mode" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;fillColor=#d97706;strokeColor=#d97706;" vertex="1" parent="1">
          <mxGeometry x="60" y="2570" width="260" height="38" as="geometry" />
        </mxCell>
        <mxCell id="bg-execute" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="3570" width="3040" height="1020" as="geometry" />
        </mxCell>
        <mxCell id="bg-execute-label" value="4. Execute adaptive discovery" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;fillColor=#0284c7;strokeColor=#0284c7;" vertex="1" parent="1">
          <mxGeometry x="60" y="3590" width="270" height="38" as="geometry" />
        </mxCell>
        <mxCell id="bg-persist" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="4630" width="3040" height="920" as="geometry" />
        </mxCell>
        <mxCell id="bg-persist-label" value="5. Persist artifacts and checkpoints" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;fillColor=#16a34a;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="60" y="4650" width="310" height="38" as="geometry" />
        </mxCell>
