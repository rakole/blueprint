        <mxCell id="bg-read-label" value="2. Read and prior-context sweep" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;fillColor=#7c3aed;strokeColor=#7c3aed;" vertex="1" parent="1">
          <mxGeometry x="60" y="1600" width="270" height="38" as="geometry" />
