<mxfile host="app.diagrams.net" modified="2026-04-28T00:00:00.000Z" agent="codex" version="24.7.8">
  <diagram id="discuss-phase-workflow-end-to-end" name="discuss-phase workflow end-to-end">
    <mxGraphModel dx="3120" dy="7900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3120" pageHeight="7900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="canvas" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3120" height="7900" as="geometry" />
        </mxCell>
        <mxCell id="title" value="&lt;div style=&quot;font-size:32px;font-weight:700;&quot;&gt;/blu-discuss-phase end-to-end workflow&lt;/div&gt;&lt;br&gt;&lt;div style=&quot;font-size:15px;margin-top:8px;&quot;&gt;Detailed presentation map from the user trigger through contract loading, MCP-owned reads, adaptive discovery, checkpointing, artifact persistence, validation repair, state refresh, checkpoint cleanup, and final routing. Every internal name is paired with a plain-English explanation.&lt;/div&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0f172a;gradientColor=#1e293b;strokeColor=#0f172a;fontColor=#ffffff;align=center;verticalAlign=middle;shadow=1;spacing=18;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="3040" height="126" as="geometry" />
        </mxCell>
        <mxCell id="legend-map-type" value="&lt;b&gt;Diagram type: swimlane activity map with decision loops&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Read left to right inside each horizontal stage, then follow the blue arrows down. Purple cards are MCP tool calls. Green cards are saved artifacts or returned state. Orange diamonds/cards are user or safety gates. Dashed yellow cards are optional capability-gated paths.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#0f172a;spacing=14;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="178" width="760" height="116" as="geometry" />
        </mxCell>
        <mxCell id="legend-names" value="&lt;b&gt;Name pattern used below&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Runtime FQN:&lt;/b&gt; mcp_blueprint_blueprint_phase_locate&lt;br&gt;&lt;b&gt;Registered tool:&lt;/b&gt; blueprint_phase_locate&lt;br&gt;&lt;b&gt;TypeScript handler:&lt;/b&gt; blueprintPhaseLocate(args)&lt;br&gt;&lt;b&gt;Plain English:&lt;/b&gt; resolve the phase number to its directory and artifacts.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="178" width="670" height="116" as="geometry" />
        </mxCell>
        <mxCell id="legend-invariant" value="&lt;b&gt;Core invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The slash command and skill shape the conversation. MCP tools own all durable state reads/writes. The runtime source of truth is &lt;code&gt;.blueprint/&lt;/code&gt;. Session helpers and subagents never replace MCP persistence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1550" y="178" width="710" height="116" as="geometry" />
        </mxCell>
        <mxCell id="legend-complete" value="&lt;b&gt;Completion means&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The phase context and optional discussion log are real authored artifacts, final state was refreshed from synced runtime truth, and the old discuss-owned checkpoint was deleted only after every finalization step succeeded.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#1e3a8a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2300" y="178" width="780" height="116" as="geometry" />
        </mxCell>
        <mxCell id="col-user" value="User and Gemini host" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="340" height="54" as="geometry" />
