        <mxCell id="bg-resolve-label" value="1. Resolve" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;fillColor=#0f766e;strokeColor=#0f766e;" vertex="1" parent="1">
