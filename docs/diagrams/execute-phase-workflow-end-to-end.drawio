        <mxCell id="bg-read" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="1500" width="3140" height="940" as="geometry" />
        </mxCell>
        <mxCell id="bg-decide" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="2480" width="3140" height="1300" as="geometry" />
