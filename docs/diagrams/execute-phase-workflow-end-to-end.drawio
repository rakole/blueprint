<mxfile host="app.diagrams.net" modified="2026-04-28T00:00:00.000Z" agent="codex" version="24.7.8">
  <diagram id="execute-phase-workflow-end-to-end" name="execute-phase workflow end-to-end">
    <mxGraphModel dx="3220" dy="9400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3220" pageHeight="9400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Canvas -->
        <mxCell id="canvas" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="3220" height="9400" as="geometry" />
        </mxCell>

        <!-- Title and legends -->
        <mxCell id="title" value="&lt;div style=&quot;font-size:32px;font-weight:700;&quot;&gt;/blu-execute-phase end-to-end workflow&lt;/div&gt;&lt;div style=&quot;font-size:15px;margin-top:8px;&quot;&gt;Presentation map from user trigger through runtime contract loading, MCP-owned target selection, wave and overwrite gates, bounded execution, summary persistence, post-write validation, synced state refresh, and implemented-only routing. Internal names are paired with simple-English explanations in every technical step.&lt;/div&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0f172a;gradientColor=#1e293b;strokeColor=#0f172a;fontColor=#ffffff;align=center;verticalAlign=middle;shadow=1;spacing=18;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="40" y="28" width="3140" height="128" as="geometry" />
        </mxCell>
        <mxCell id="legend-kind" value="&lt;b&gt;Diagram type: swimlane activity map plus decision lattice&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Read top to bottom. Inside each stage, scan left to right: user and host, command and skill policy, session helpers or executors, MCP calls, tool internals, then durable artifacts and routes. Blue arrows show the normal path. Orange and red cards show gates, blockers, and stop paths.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#0f172a;spacing=14;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="760" height="140" as="geometry" />
        </mxCell>
        <mxCell id="legend-name-pattern" value="&lt;b&gt;Name pattern used below&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;b&gt;Runtime FQN&lt;/b&gt;: &lt;code&gt;mcp_blueprint_blueprint_phase_summary_write&lt;/code&gt;&lt;br&gt;&lt;b&gt;Registered MCP tool&lt;/b&gt;: &lt;code&gt;blueprint_phase_summary_write&lt;/code&gt;&lt;br&gt;&lt;b&gt;TypeScript handler&lt;/b&gt;: &lt;code&gt;blueprintPhaseSummaryWrite(args)&lt;/code&gt;&lt;br&gt;&lt;b&gt;Plain English&lt;/b&gt;: save one validated execution summary for one saved plan through Blueprint, not by hand-editing a file.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#8b5cf6;fontColor=#2e1065;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="190" width="780" height="140" as="geometry" />
        </mxCell>
        <mxCell id="legend-color" value="&lt;b&gt;Color key&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Blue: user or host entry. Gray: command and skill contract. Yellow: session helpers and optional executors. Purple: MCP calls. Cyan: deterministic tool internals. Green: artifacts, evidence, and routes. Orange/red: decisions, blockers, or hard stops.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontColor=#7c2d12;spacing=14;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1660" y="190" width="700" height="140" as="geometry" />
        </mxCell>
        <mxCell id="legend-invariant" value="&lt;b&gt;Core invariant&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The command and skill own user-facing orchestration. MCP tools own deterministic state reads and writes. The command may execute real repo changes, but Blueprint runtime persistence is limited to one &lt;code&gt;XX-YY-SUMMARY.md&lt;/code&gt; per executed plan plus synced &lt;code&gt;.blueprint/STATE.md&lt;/code&gt;. No execute-phase report is persisted.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2400" y="190" width="780" height="140" as="geometry" />
        </mxCell>

        <!-- Column headers -->
        <mxCell id="col-user" value="User and Gemini host" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontColor=#1e3a8a;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="80" y="385" width="360" height="56" as="geometry" />
        </mxCell>
        <mxCell id="col-command" value="Command manifest and skill" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontColor=#0f172a;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="480" y="385" width="440" height="56" as="geometry" />
        </mxCell>
        <mxCell id="col-agents" value="Session helpers and executors" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;fontStyle=1;fontSize=14;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="960" y="385" width="430" height="56" as="geometry" />
