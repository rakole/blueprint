        <mxCell id="bg-persist" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="4940" width="3140" height="980" as="geometry" />
        </mxCell>
        <mxCell id="bg-validate" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry x="40" y="5960" width="3140" height="920" as="geometry" />
        </mxCell>
        <mxCell id="bg-route" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#e2e8f0;" vertex="1" parent="1">
          <mxGeometry x="40" y="6920" width="3140" height="720" as="geometry" />
        </mxCell>
        <mxCell id="bg-decision-lattice" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fed7aa;" vertex="1" parent="1">
          <mxGeometry x="40" y="7680" width="3140" height="820" as="geometry" />
        </mxCell>
        <mxCell id="bg-glossary" value="" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;" vertex="1" parent="1">
          <mxGeometry x="40" y="8540" width="3140" height="700" as="geometry" />
        </mxCell>

        <!-- Stage labels -->
        <mxCell id="stage-entry" value="Entry and runtime contract loading" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#1d4ed8;strokeColor=#1d4ed8;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-resolve" value="1. Resolve" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0f766e;strokeColor=#0f766e;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="940" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-read" value="2. Read" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#7c3aed;strokeColor=#7c3aed;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="1520" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-decide" value="3. Decide" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#d97706;strokeColor=#d97706;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="2500" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-execute" value="4. Execute" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0284c7;strokeColor=#0284c7;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="3840" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-persist" value="5. Persist" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#16a34a;strokeColor=#16a34a;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="4960" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-validate" value="6. Validate and sync" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#9333ea;strokeColor=#9333ea;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="5980" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-route" value="7. Route and report" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#047857;strokeColor=#047857;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="6940" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-lattice" value="Decision lattice" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ea580c;strokeColor=#ea580c;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="7700" width="230" height="40" as="geometry" />
        </mxCell>
        <mxCell id="stage-glossary" value="Tool glossary and artifact map" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#334155;strokeColor=#334155;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;fontFamily=Inter;" vertex="1" parent="1">
          <mxGeometry x="60" y="8560" width="270" height="40" as="geometry" />
        </mxCell>

        <!-- Entry cards -->
        <mxCell id="entry-user-trigger" value="&lt;b&gt;User trigger&lt;/b&gt;&lt;br&gt;&lt;code&gt;/blu-execute-phase &amp;lt;phase&amp;gt; [--wave N] [--gaps-only] [--interactive]&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: execute already-saved phase plans. This command does not invent plans; it turns selected plan work into implementation plus summary evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="555" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-router" value="&lt;b&gt;Optional root form&lt;/b&gt;&lt;br&gt;&lt;code&gt;/blu execute-phase&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: the root router may dispatch here only because the live command catalog says &lt;code&gt;execute-phase&lt;/code&gt; is &lt;code&gt;implemented&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="725" width="360" height="115" as="geometry" />
        </mxCell>
        <mxCell id="entry-manifest" value="&lt;b&gt;Command manifest&lt;/b&gt;&lt;br&gt;&lt;code&gt;commands/blu-execute-phase.toml&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: thin host entrypoint. It names the primary skill, long-running mutation profile, visible stage vocabulary, allowed MCP calls, overwrite expectations, and no-report rule.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="555" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-skill" value="&lt;b&gt;Primary skill&lt;/b&gt;&lt;br&gt;&lt;code&gt;skills/blueprint-phase-execution/SKILL.md&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: shared execution-family policy. For this command it loads only &lt;code&gt;execute-phase-runtime-contract.md&lt;/code&gt; plus the long-running profile; &lt;code&gt;quick&lt;/code&gt; and &lt;code&gt;fast&lt;/code&gt; details stay out of scope.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="725" width="440" height="115" as="geometry" />
        </mxCell>
        <mxCell id="entry-helpers" value="&lt;b&gt;Session-local visibility&lt;/b&gt;&lt;br&gt;&lt;code&gt;update_topic&lt;/code&gt; and &lt;code&gt;write_todos&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: keep the live run understandable during long work. These helpers do not persist Blueprint state and do not replace MCP summaries or &lt;code&gt;STATE.md&lt;/code&gt;. If unavailable, use concise prose progress instead.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;strokeWidth=2;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="555" width="430" height="150" as="geometry" />
        </mxCell>
        <mxCell id="entry-status-vocab" value="&lt;b&gt;Visible run vocabulary&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Stages: &lt;code&gt;Resolve&lt;/code&gt;, &lt;code&gt;Read&lt;/code&gt;, &lt;code&gt;Decide&lt;/code&gt;, &lt;code&gt;Execute&lt;/code&gt;, &lt;code&gt;Persist&lt;/code&gt;, &lt;code&gt;Validate&lt;/code&gt;, &lt;code&gt;Route&lt;/code&gt;.&lt;br&gt;Status fields: resolved scope, active stage, pending gate, execution mode, next safe action.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="725" width="430" height="115" as="geometry" />
        </mxCell>
        <mxCell id="entry-allowed-tools" value="&lt;b&gt;Allowed deterministic state tools&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Only the execute-phase contract tools may select targets or persist state: phase locate, plan index/read, summary index/read/write, execution targets, config get, artifact contract read, artifact validate, state load, and state update.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="555" width="520" height="285" as="geometry" />
        </mxCell>
        <mxCell id="entry-invariant" value="&lt;b&gt;Runtime boundary&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Blueprint slash commands are host entrypoints, not shell executables. Runtime persistence belongs under &lt;code&gt;.blueprint/&lt;/code&gt;. Scripts and hooks can assist locally, but the command contract keeps durable phase state on MCP rails.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="555" width="520" height="285" as="geometry" />
        </mxCell>
        <mxCell id="entry-artifacts-preview" value="&lt;b&gt;What this workflow may leave behind&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Created or updated: &lt;code&gt;.blueprint/phases/&amp;lt;phase&amp;gt;/XX-YY-SUMMARY.md&lt;/code&gt; for each executed plan and &lt;code&gt;.blueprint/STATE.md&lt;/code&gt; after sync.&lt;br&gt;&lt;br&gt;Not created: execute-phase reports, freehand checkpoint files, or ad hoc summary paths.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="555" width="590" height="285" as="geometry" />
        </mxCell>

        <!-- Resolve cards -->
        <mxCell id="resolve-scope" value="&lt;b&gt;Resolve scope shown to user&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Active stage: &lt;code&gt;Resolve&lt;/code&gt;.&lt;br&gt;Pending gate: phase identification.&lt;br&gt;Execution mode: not chosen yet.&lt;br&gt;Next safe action: resolve phase or route to &lt;code&gt;/blu-progress&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="1025" width="360" height="140" as="geometry" />
        </mxCell>
        <mxCell id="resolve-policy" value="&lt;b&gt;Input policy&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Pass only a numeric phase reference when provided, or omit phase to let Blueprint infer from state. Do not pass slugs, directories, filenames, or combined tokens as the phase argument.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1025" width="440" height="140" as="geometry" />
        </mxCell>
        <mxCell id="resolve-call" value="&lt;b&gt;MCP call&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_locate&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Registered tool: &lt;code&gt;blueprint_phase_locate&lt;/code&gt;&lt;br&gt;Handler: &lt;code&gt;blueprintPhaseLocate(args)&lt;/code&gt;&lt;br&gt;Plain English: find the target phase number, phase folder, phase prefix, and known phase artifacts safely.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;strokeWidth=2;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="1025" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="resolve-internals" value="&lt;b&gt;Tool decision&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If found, normalize the phase into &lt;code&gt;phaseNumber&lt;/code&gt;, &lt;code&gt;phasePrefix&lt;/code&gt;, &lt;code&gt;phaseName&lt;/code&gt;, &lt;code&gt;phaseDir&lt;/code&gt;, and &lt;code&gt;artifacts&lt;/code&gt;.&lt;br&gt;&lt;br&gt;If not found, return a precise &lt;code&gt;reason&lt;/code&gt; instead of letting the command guess where to write.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="1025" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="resolve-output" value="&lt;b&gt;Resolved phase boundary&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Example output: &lt;code&gt;phaseNumber=3&lt;/code&gt;, &lt;code&gt;phasePrefix=03&lt;/code&gt;, &lt;code&gt;phaseDir=.blueprint/phases/03-phase-discovery&lt;/code&gt;.&lt;br&gt;&lt;br&gt;Plain English: later summary writes are locked to this selected phase scope.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="1025" width="590" height="170" as="geometry" />
        </mxCell>
        <mxCell id="resolve-stop" value="&lt;b&gt;Stop path: phase unresolved&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Return the tool's &lt;code&gt;reason&lt;/code&gt;, explain the recovery path, and route to &lt;code&gt;/blu-progress&lt;/code&gt; as the safe implemented command. No execution and no summary write occurs.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;strokeWidth=2;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="1220" width="590" height="150" as="geometry" />
        </mxCell>

        <!-- Read cards -->
        <mxCell id="read-user-status" value="&lt;b&gt;Live status during read&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Active stage: &lt;code&gt;Read&lt;/code&gt;.&lt;br&gt;Pending gate: saved plans, existing summaries, config, artifact health, and state truth.&lt;br&gt;Plain English: gather everything needed before real repo mutation or summary writes.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="1605" width="360" height="190" as="geometry" />
        </mxCell>
        <mxCell id="read-command-policy" value="&lt;b&gt;Pre-mutation read policy&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Before any write, the command must read plan index, summary index, execution targets, effective config, artifact validation, and state. After target selection, it reads every selected plan and any selected or overlapping summaries.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1605" width="440" height="190" as="geometry" />
        </mxCell>
        <mxCell id="read-mcp-primary" value="&lt;b&gt;Primary read bundle&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_index&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_summary_index&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_execution_targets&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_config_get&lt;/code&gt; with &lt;code&gt;scope: effective&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_artifact_validate&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_state_load&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: compute what can be executed, how it should run, and what state already says.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;strokeWidth=2;fontColor=#3b0764;spacing=12;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="1605" width="520" height="305" as="geometry" />
        </mxCell>
        <mxCell id="read-plan-index" value="&lt;b&gt;Plan index internals&lt;/b&gt;&lt;br&gt;&lt;code&gt;blueprintPhasePlanIndex(args)&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: scan canonical &lt;code&gt;XX-YY-PLAN.md&lt;/code&gt; files, parse each plan id, wave, dependency list, validity, warnings, and explicit &lt;code&gt;gap_closure: true&lt;/code&gt; marker. Returns &lt;code&gt;plans&lt;/code&gt;, &lt;code&gt;waves&lt;/code&gt;, &lt;code&gt;missingPlans&lt;/code&gt;, and &lt;code&gt;gapClosurePlans&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="1605" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="read-summary-index" value="&lt;b&gt;Summary index internals&lt;/b&gt;&lt;br&gt;&lt;code&gt;blueprintPhaseSummaryIndex(args)&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: scan canonical &lt;code&gt;XX-YY-SUMMARY.md&lt;/code&gt; files and validate each. Only valid summaries with &lt;code&gt;Status: COMPLETED&lt;/code&gt;, a valid linked plan, and no missing dependency plans close execution debt. Valid &lt;code&gt;PARTIAL&lt;/code&gt; or &lt;code&gt;BLOCKED&lt;/code&gt; summaries remain pending carry-forward evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="1815" width="520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="read-execution-targets" value="&lt;b&gt;Execution target helper internals&lt;/b&gt;&lt;br&gt;&lt;code&gt;blueprintPhaseExecutionTargets(args)&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: deterministically choose target plans. It starts from &lt;code&gt;summaryIndex.pendingPlans&lt;/code&gt;, filters to &lt;code&gt;gapClosurePlans&lt;/code&gt; for &lt;code&gt;--gaps-only&lt;/code&gt;, filters by requested &lt;code&gt;wave&lt;/code&gt; when present, otherwise selects the lowest pending wave, then returns blockers, overwrite candidates, overlapping plans, and conflict groups.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;strokeWidth=2;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="2065" width="520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="read-selected-details" value="&lt;b&gt;Detail reads after target selection&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_plan_read&lt;/code&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_summary_read&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: read every selected plan body and read existing summaries for selected or overlapping plan ids before deciding whether to reuse, replace, carry forward, or block.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="1930" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="read-artifacts" value="&lt;b&gt;Read surfaces&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;.blueprint/config.json&lt;/code&gt; for normalized execution settings.&lt;br&gt;&lt;code&gt;.blueprint/STATE.md&lt;/code&gt; for current routing truth.&lt;br&gt;&lt;code&gt;.blueprint/phases/&amp;lt;phase&amp;gt;/XX-YY-PLAN.md&lt;/code&gt; for saved plan scope.&lt;br&gt;&lt;code&gt;.blueprint/phases/&amp;lt;phase&amp;gt;/XX-YY-SUMMARY.md&lt;/code&gt; for prior evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="1605" width="590" height="305" as="geometry" />
        </mxCell>
        <mxCell id="read-effective-config" value="&lt;b&gt;Effective config read&lt;/b&gt;&lt;br&gt;&lt;code&gt;blueprint_config_get&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: normalized config decides whether to describe parallel execution, worktree isolation, and branch posture. The important fields are &lt;code&gt;parallelization.*&lt;/code&gt;, &lt;code&gt;workflow.use_worktrees&lt;/code&gt;, and &lt;code&gt;git.branching_strategy&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="1930" width="590" height="190" as="geometry" />
        </mxCell>
        <mxCell id="read-state-health" value="&lt;b&gt;Artifact health and state truth&lt;/b&gt;&lt;br&gt;&lt;code&gt;blueprint_artifact_validate&lt;/code&gt; and &lt;code&gt;blueprint_state_load&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: catch schema drift, code-review or regression warnings, blockers, and current next-action signals before doing work that would create new evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="2140" width="590" height="155" as="geometry" />
        </mxCell>

        <!-- Decide cards -->
        <mxCell id="decide-user-status" value="&lt;b&gt;Live status during decide&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Active stage: &lt;code&gt;Decide&lt;/code&gt;.&lt;br&gt;Pending gates: target set, lower-wave blockers, stale plans, overwrite confirmation, overlap review, and execution mode choice.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="2585" width="360" height="165" as="geometry" />
        </mxCell>
        <mxCell id="decide-target-selection" value="&lt;b&gt;Target-selection policy&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Default run: execute the lowest pending wave only.&lt;br&gt;&lt;code&gt;--wave N&lt;/code&gt;: choose pending plans in that wave.&lt;br&gt;&lt;code&gt;--gaps-only&lt;/code&gt;: choose only plans whose saved plan metadata has &lt;code&gt;gap_closure: true&lt;/code&gt;.&lt;br&gt;Combined &lt;code&gt;--wave&lt;/code&gt; and &lt;code&gt;--gaps-only&lt;/code&gt; still cannot skip lower-wave pending work.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="2585" width="440" height="230" as="geometry" />
        </mxCell>
        <mxCell id="decide-target-output" value="&lt;b&gt;Target helper output&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;pendingPlanIds&lt;/code&gt;: plans not closed by valid completed summaries.&lt;br&gt;&lt;code&gt;candidatePlanIds&lt;/code&gt;: pending plans after wave and gap filters.&lt;br&gt;&lt;code&gt;selectedPlanIds&lt;/code&gt;: the actual plans this run may execute.&lt;br&gt;&lt;code&gt;lowerWavePendingPlans&lt;/code&gt;: earlier unfinished plans that block later waves.&lt;br&gt;&lt;code&gt;overwriteCandidatePlanIds&lt;/code&gt;: selected pending plans that already have a summary.&lt;br&gt;&lt;code&gt;overlapPlanIds&lt;/code&gt; and &lt;code&gt;conflicts.groups&lt;/code&gt;: plans that share write surfaces.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontColor=#3b0764;spacing=12;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="2585" width="520" height="315" as="geometry" />
        </mxCell>
        <mxCell id="decide-plan-blockers" value="&lt;b&gt;Hard blockers&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Stop before execution when selected plans are invalid, stale, unreadable, or missing dependency plan artifacts. If no valid plan artifacts exist at all, route to &lt;code&gt;/blu-plan-phase&lt;/code&gt;. If no pending targets remain, report that no execution was needed and route from refreshed state instead of pretending work ran.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;strokeWidth=2;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="2585" width="520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="decide-lower-wave" value="&lt;b&gt;Lower-wave gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Any &lt;code&gt;lowerWavePendingPlans&lt;/code&gt; entry is an absolute blocker for later-wave execution. Plain English: do not jump to wave 2 while wave 1 still has unfinished plans, even if the user requested &lt;code&gt;--wave 2&lt;/code&gt; or &lt;code&gt;--gaps-only --wave 2&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="2835" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="decide-summary-reuse" value="&lt;b&gt;Existing summary decision&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Valid &lt;code&gt;COMPLETED&lt;/code&gt; summary: reuse by default; replace only after explicit overwrite confirmation.&lt;br&gt;Valid &lt;code&gt;PARTIAL&lt;/code&gt; or &lt;code&gt;BLOCKED&lt;/code&gt; summary: durable carry-forward evidence, but plan remains pending.&lt;br&gt;Malformed summary: repair or replace target, not completion evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="3045" width="520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="decide-overwrite" value="&lt;b&gt;Structured confirmation path&lt;/b&gt;&lt;br&gt;&lt;code&gt;ask_user&lt;/code&gt; when available&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: ask focused questions for overwrite, review, skip, stop, or retry choices. If the host lacks &lt;code&gt;ask_user&lt;/code&gt;, ask the same focused decision in prose; do not invent a substitute tool.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;strokeWidth=2;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="2585" width="430" height="230" as="geometry" />
        </mxCell>
        <mxCell id="decide-conflict" value="&lt;b&gt;Ownership and overlap gate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Compare selected plans' &lt;code&gt;files_modified&lt;/code&gt;, generated artifacts, read-first surfaces, and other shared write surfaces. Disjoint write ownership may run in parallel. Overlap means run sequentially or stop for explicit confirmation.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="2585" width="590" height="230" as="geometry" />
        </mxCell>
        <mxCell id="decide-config" value="&lt;b&gt;Execution mode from config&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Fields that shape behavior: &lt;code&gt;parallelization.enabled&lt;/code&gt;, &lt;code&gt;parallelization.plan_level&lt;/code&gt;, &lt;code&gt;parallelization.max_concurrent_agents&lt;/code&gt;, &lt;code&gt;parallelization.min_plans_for_parallel&lt;/code&gt;, &lt;code&gt;workflow.use_worktrees&lt;/code&gt;, and &lt;code&gt;git.branching_strategy&lt;/code&gt;. Plain English: explain whether execution is parallel, sequential, worktree-isolated, or current-branch scoped.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="2835" width="590" height="230" as="geometry" />
        </mxCell>
        <mxCell id="decide-ready" value="&lt;b&gt;Ready to execute when all gates pass&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The command has selected plan ids, read plan bodies, read relevant summaries, named blockers or overlap decisions, selected a safe execution mode, and knows which summaries will be created, reused, replaced, partial, or blocked.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontColor=#14532d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="3085" width="590" height="190" as="geometry" />
        </mxCell>

        <!-- Execute cards -->
        <mxCell id="execute-user-status" value="&lt;b&gt;Live status during execute&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Active stage: &lt;code&gt;Execute&lt;/code&gt;.&lt;br&gt;Pending gate: current plan or task group.&lt;br&gt;Execution mode: parallel executors, sequential fallback, or interactive checkpointed run.&lt;br&gt;Next safe action: complete current plan, write truthful summary, or stop on blocker.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="3925" width="360" height="210" as="geometry" />
        </mxCell>
        <mxCell id="execute-command-policy" value="&lt;b&gt;Plan-aware execution policy&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Preserve wave order. Do not collapse all selected plans into one monolithic task. Execute one selected plan or one explicitly confirmed bounded batch at a time, with acceptance criteria and dependencies visible.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="3925" width="440" height="210" as="geometry" />
        </mxCell>
        <mxCell id="execute-agent-path" value="&lt;b&gt;Optional parallel path&lt;/b&gt;&lt;br&gt;&lt;code&gt;blueprint-executor&lt;/code&gt; subagents&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: use bounded executor agents only when plans have disjoint write ownership and config allows it. Each prompt names exactly one plan or confirmed batch, write-owned files or surfaces, read-first files, isolation expectations, required verification, and a summary draft requirement.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;strokeWidth=2;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="3925" width="430" height="255" as="geometry" />
        </mxCell>
        <mxCell id="execute-fallback" value="&lt;b&gt;Sequential inline fallback&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Used when subagents are unavailable, disabled, unreliable, unsafe due to overlapping writes, or when interactive mode asks for checkpoints. Plain English: the main agent executes one plan or major task group, verifies it, persists a summary, then moves on only if still safe.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontColor=#78350f;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="4200" width="430" height="220" as="geometry" />
        </mxCell>
        <mxCell id="execute-real-work" value="&lt;b&gt;Real implementation work&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: read the files the plan names, edit the repo as needed, run shell commands or tests that the plan requires, and keep changes scoped to the plan. Hooks such as read-before-edit, Blueprint write guard, and workflow advisory can warn, but they do not own state.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="3925" width="520" height="210" as="geometry" />
        </mxCell>
        <mxCell id="execute-verification" value="&lt;b&gt;Targeted verification and repair loop&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Run the plan's targeted checks before any &lt;code&gt;COMPLETED&lt;/code&gt; claim. Repair only issues caused by current changes and cap repeated attempts. If tests fail or acceptance criteria are unverified, draft a truthful &lt;code&gt;PARTIAL&lt;/code&gt; or &lt;code&gt;BLOCKED&lt;/code&gt; summary instead of pretending completion.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;strokeWidth=2;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="4155" width="520" height="250" as="geometry" />
        </mxCell>
        <mxCell id="execute-checkpoint" value="&lt;b&gt;Durable continuation rule&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;There is no dedicated execute-phase checkpoint file. After each plan or major task group, durable continuation evidence comes from the latest persisted summary: completed work, current task, blocker, verification state, and next safe action.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="3925" width="590" height="210" as="geometry" />
        </mxCell>
        <mxCell id="execute-interactive" value="&lt;b&gt;Interactive checkpoints&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;In interactive runs, after each plan or major task group ask whether to &lt;code&gt;review&lt;/code&gt;, &lt;code&gt;skip&lt;/code&gt;, &lt;code&gt;stop&lt;/code&gt;, or &lt;code&gt;retry&lt;/code&gt;. Plain English: long execution stays under user control without inventing another persistence mechanism.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="4155" width="590" height="250" as="geometry" />
        </mxCell>
        <mxCell id="execute-stop-gates" value="&lt;b&gt;Stop or pause execution when&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Overlap cannot be made safe, lower-wave debt appears, repeated verification fails, user chooses stop, a plan's dependency is missing, or a write surface would escape the selected scope. The next artifact should be a truthful partial or blocked summary when work started, or no summary when execution never began.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;strokeWidth=2;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="4375" width="910" height="250" as="geometry" />
        </mxCell>

        <!-- Persist cards -->
        <mxCell id="persist-user-status" value="&lt;b&gt;Live status during persist&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Active stage: &lt;code&gt;Persist&lt;/code&gt;.&lt;br&gt;Pending gate: summary contract and summary write validation.&lt;br&gt;Plain English: convert execution evidence into canonical Blueprint summary files.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="5045" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="persist-policy" value="&lt;b&gt;Persistence policy&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Before writing or replacing any summary, read the canonical &lt;code&gt;phase.summary&lt;/code&gt; contract. Persist exactly one summary per executed plan through MCP. Do not hand-build summary paths or write freehand summary files.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="5045" width="440" height="180" as="geometry" />
        </mxCell>
        <mxCell id="persist-contract-call" value="&lt;b&gt;Contract read&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_artifact_contract_read&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Arguments: &lt;code&gt;artifactId: phase.summary&lt;/code&gt;.&lt;br&gt;Registered tool: &lt;code&gt;blueprint_artifact_contract_read&lt;/code&gt;.&lt;br&gt;Plain English: fetch the official summary template and required headings before authoring evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="5045" width="520" height="215" as="geometry" />
        </mxCell>
        <mxCell id="persist-contract-details" value="&lt;b&gt;&lt;code&gt;phase.summary&lt;/code&gt; contract&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Required markers: &lt;code&gt;**Plan:**&lt;/code&gt; and &lt;code&gt;**Status:**&lt;/code&gt;.&lt;br&gt;Allowed statuses: &lt;code&gt;COMPLETED&lt;/code&gt;, &lt;code&gt;PARTIAL&lt;/code&gt;, &lt;code&gt;BLOCKED&lt;/code&gt;.&lt;br&gt;Required headings: Outcome, Changes Made, Verification, Follow-Ups, Evidence.&lt;br&gt;Plain English: the summary must say what happened, what changed, how it was checked, what remains, and where evidence lives.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="5045" width="520" height="215" as="geometry" />
        </mxCell>
        <mxCell id="persist-write-call" value="&lt;b&gt;Summary write&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_summary_write&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Registered tool: &lt;code&gt;blueprint_phase_summary_write&lt;/code&gt;&lt;br&gt;Handler: &lt;code&gt;blueprintPhaseSummaryWrite(args)&lt;/code&gt;&lt;br&gt;Arguments: numeric &lt;code&gt;phase&lt;/code&gt;, numeric &lt;code&gt;planId&lt;/code&gt;, full summary &lt;code&gt;content&lt;/code&gt;, and &lt;code&gt;overwrite: true&lt;/code&gt; only after explicit confirmation.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;strokeWidth=2;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="5290" width="520" height="245" as="geometry" />
        </mxCell>
        <mxCell id="persist-write-internals" value="&lt;b&gt;Write validation internals&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;The handler confirms the matching plan exists and is valid, dependency plan artifacts exist, the summary starts with H1, the &lt;code&gt;Plan&lt;/code&gt; marker matches the linked plan, required sections are populated, placeholder scaffold text is gone, and existing files are not replaced unless overwrite was confirmed.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;strokeWidth=2;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="5290" width="520" height="245" as="geometry" />
        </mxCell>
        <mxCell id="persist-summary-artifact" value="&lt;b&gt;Durable summary artifact&lt;/b&gt;&lt;br&gt;&lt;code&gt;.blueprint/phases/&amp;lt;phase&amp;gt;/XX-YY-SUMMARY.md&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Return fields &lt;code&gt;path&lt;/code&gt; and &lt;code&gt;linkedPlanPath&lt;/code&gt; are authoritative. Plain English: trust the MCP tool's resolved paths; do not reconstruct filenames from chat memory.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;strokeWidth=2;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="5045" width="590" height="215" as="geometry" />
        </mxCell>
        <mxCell id="persist-status-result" value="&lt;b&gt;Write result semantics&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;created&lt;/code&gt;: new summary saved.&lt;br&gt;&lt;code&gt;updated&lt;/code&gt;: existing summary replaced after confirmation.&lt;br&gt;&lt;code&gt;reused&lt;/code&gt;: unchanged summary preserved.&lt;br&gt;&lt;code&gt;invalid&lt;/code&gt;: content or linked plan failed validation.&lt;br&gt;Plain English: the command must report which case happened per plan.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="5290" width="590" height="245" as="geometry" />
        </mxCell>
        <mxCell id="persist-no-reports" value="&lt;b&gt;No report persistence&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Do not call report write tools. Do not persist &lt;code&gt;.blueprint/reports/execute-phase-*.md&lt;/code&gt;. The command's durable evidence is plan-linked summaries plus synced state only.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;strokeWidth=2;fontColor=#7f1d1d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="5275" width="440" height="260" as="geometry" />
        </mxCell>

        <!-- Validate and sync cards -->
        <mxCell id="validate-user-status" value="&lt;b&gt;Live status during validate&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Active stage: &lt;code&gt;Validate&lt;/code&gt;.&lt;br&gt;Pending gate: refreshed summary index, artifact validation, and state sync.&lt;br&gt;Plain English: prove the saved evidence now tells the truth before recommending the next command.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="6065" width="360" height="190" as="geometry" />
        </mxCell>
        <mxCell id="validate-policy" value="&lt;b&gt;Post-write order is fixed&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;After summary writes finish, run summary index again, then artifact validation, then state update with &lt;code&gt;base: synced&lt;/code&gt;. Plain English: state follows refreshed artifact truth, not stale memory from before execution.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="6065" width="440" height="190" as="geometry" />
        </mxCell>
        <mxCell id="validate-summary-index-call" value="&lt;b&gt;Post-write summary index&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_phase_summary_index&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: recompute &lt;code&gt;completedPlans&lt;/code&gt; and &lt;code&gt;pendingPlans&lt;/code&gt; from saved summaries after the run. This is where &lt;code&gt;PARTIAL&lt;/code&gt;, &lt;code&gt;BLOCKED&lt;/code&gt;, invalid summaries, lower-wave debt, and filtered runs stay visible.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;strokeWidth=2;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="6065" width="520" height="210" as="geometry" />
        </mxCell>
        <mxCell id="validate-artifact-call" value="&lt;b&gt;Artifact validation&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_artifact_validate&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: run Blueprint artifact health checks after writes. If schema drift, malformed summaries, or suggested repairs remain, name them truthfully instead of hiding them behind a success message.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="6295" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="validate-state-call" value="&lt;b&gt;Synced state update&lt;/b&gt;&lt;br&gt;&lt;code&gt;mcp_blueprint_blueprint_state_update&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Arguments include &lt;code&gt;base: synced&lt;/code&gt;.&lt;br&gt;Plain English: refresh &lt;code&gt;.blueprint/STATE.md&lt;/code&gt; from the now-current summary and artifact truth so next-action guidance is not stale.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;strokeWidth=2;fontColor=#3b0764;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="6505" width="520" height="190" as="geometry" />
        </mxCell>
        <mxCell id="validate-internals" value="&lt;b&gt;Truth-preserving validation&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Do not mark a whole phase complete from partial coverage. Keep these visible: pending plans, lower-wave debt, failed tests, partial or blocked summaries, invalid summaries, gap-only coverage, filtered wave runs, and acceptance criteria that were not verified.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;strokeWidth=2;fontColor=#0c4a6e;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="6065" width="520" height="305" as="geometry" />
        </mxCell>
        <mxCell id="validate-state-artifact" value="&lt;b&gt;Updated state artifact&lt;/b&gt;&lt;br&gt;&lt;code&gt;.blueprint/STATE.md&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: Blueprint's project-local state now reflects what summaries actually prove. The state update may shift next action to validation, progress, more execution, or repair depending on the evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;strokeWidth=2;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="6065" width="590" height="210" as="geometry" />
        </mxCell>
        <mxCell id="validate-no-completion-claim" value="&lt;b&gt;No phase-level completion claim&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;/blu-execute-phase&lt;/code&gt; records execution evidence but does not certify the phase as complete. Plain English: implementation summaries are not the same thing as validation sign-off or UAT confidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;strokeWidth=2;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="6295" width="590" height="190" as="geometry" />
        </mxCell>

        <!-- Route cards -->
        <mxCell id="route-user-status" value="&lt;b&gt;Final user-facing report&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Active stage: &lt;code&gt;Route&lt;/code&gt;.&lt;br&gt;Plain English: tell the user which plans or waves were executed, which summaries were created, reused, replaced, partial, or blocked, what checks ran, what warnings remain, and the next safe implemented action.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="7025" width="360" height="210" as="geometry" />
        </mxCell>
        <mxCell id="route-policy" value="&lt;b&gt;Implemented-only routing&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Route only to commands whose runtime catalog entry is &lt;code&gt;implemented&lt;/code&gt;. If the natural next step is ambiguous or unavailable, prefer &lt;code&gt;/blu-progress&lt;/code&gt;. Do not present planned-only commands as runnable follow-ups.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="7025" width="440" height="210" as="geometry" />
        </mxCell>
        <mxCell id="route-next-validate" value="&lt;b&gt;Normal next lifecycle handoff&lt;/b&gt;&lt;br&gt;&lt;code&gt;/blu-validate-phase &amp;lt;phase&amp;gt;&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: once execution summaries exist, validation checks whether the phase evidence actually satisfies the plan and phase criteria. That is the first place a phase-level completion claim can start to become legitimate.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;strokeWidth=2;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="7025" width="520" height="210" as="geometry" />
        </mxCell>
        <mxCell id="route-next-verify" value="&lt;b&gt;Verifier follow-up after validation evidence&lt;/b&gt;&lt;br&gt;&lt;code&gt;/blu-verify-work&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: verify-work belongs after validation evidence exists. Execute-phase may mention it as a later verifier follow-up, not as a replacement for validation.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="7255" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="route-progress" value="&lt;b&gt;Ambiguous or blocked next step&lt;/b&gt;&lt;br&gt;&lt;code&gt;/blu-progress&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Plain English: when state, filters, blockers, invalid artifacts, or implementation status make the safest next action unclear, route to progress rather than guessing.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="7025" width="520" height="210" as="geometry" />
        </mxCell>
        <mxCell id="route-more-execute" value="&lt;b&gt;More execution may remain&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;If the run was wave-filtered, gap-only, stopped after a partial summary, or blocked by lower-wave debt, the next safe action may be another scoped &lt;code&gt;/blu-execute-phase&lt;/code&gt; run after the named blocker is resolved.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1990" y="7255" width="520" height="170" as="geometry" />
        </mxCell>
        <mxCell id="route-final-artifacts" value="&lt;b&gt;End state&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;User sees a concise execution result. Repo contains only valid command-owned runtime artifacts: plan-linked summaries and synced state. Any warnings, blockers, failed checks, or partial coverage remain visible for the next command.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontColor=#14532d;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2550" y="7025" width="590" height="400" as="geometry" />
        </mxCell>

        <!-- Decision lattice -->
        <mxCell id="lattice-title" value="&lt;b&gt;Decision lattice for presentation Q and A&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Use this row as the fast reference when someone asks, &quot;What happens if... ?&quot; Each card names the trigger, internal field or tool signal, and the safe behavior.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#0f172a;spacing=12;fontSize=13;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="7700" width="2780" height="75" as="geometry" />
        </mxCell>
        <mxCell id="lattice-phase-missing" value="&lt;b&gt;Phase missing or ambiguous&lt;/b&gt;&lt;br&gt;&lt;code&gt;phase_locate.found=false&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Stop, show tool reason, route to &lt;code&gt;/blu-progress&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontColor=#7f1d1d;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="7825" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="lattice-no-plans" value="&lt;b&gt;No valid saved plans&lt;/b&gt;&lt;br&gt;&lt;code&gt;planIndex.plans=[]&lt;/code&gt; or invalid selected plans&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Do not execute. Repair or route to &lt;code&gt;/blu-plan-phase&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontColor=#7f1d1d;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="7825" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="lattice-lower-wave" value="&lt;b&gt;Later wave requested too early&lt;/b&gt;&lt;br&gt;&lt;code&gt;lowerWavePendingPlans.length &amp;gt; 0&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Block later wave. Execute or repair earlier pending plans first.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="7825" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="lattice-gaps-only" value="&lt;b&gt;Gap-only run&lt;/b&gt;&lt;br&gt;&lt;code&gt;gapsOnly=true&lt;/code&gt; filters to &lt;code&gt;gapClosurePlans&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Do not infer gap closure from missing summaries alone.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1250" y="7825" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="lattice-overlap" value="&lt;b&gt;Plan overlap&lt;/b&gt;&lt;br&gt;&lt;code&gt;conflicts.groups&lt;/code&gt; or &lt;code&gt;overlapPlanIds&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Parallel only if disjoint. Otherwise sequential or explicit confirmation.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1640" y="7825" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="lattice-overwrite" value="&lt;b&gt;Existing summary&lt;/b&gt;&lt;br&gt;&lt;code&gt;overwriteCandidatePlanIds&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Completed is reused by default. Replacement requires explicit overwrite confirmation.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2030" y="7825" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="lattice-partial" value="&lt;b&gt;Partial or blocked evidence&lt;/b&gt;&lt;br&gt;&lt;code&gt;Status: PARTIAL&lt;/code&gt; or &lt;code&gt;BLOCKED&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Keep as carry-forward evidence, but plan remains pending.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2420" y="7825" width="360" height="135" as="geometry" />
        </mxCell>
        <mxCell id="lattice-verification-fails" value="&lt;b&gt;Verification fails&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Run bounded repair for current-change failures. If still failing, persist &lt;code&gt;PARTIAL&lt;/code&gt; or &lt;code&gt;BLOCKED&lt;/code&gt;, not &lt;code&gt;COMPLETED&lt;/code&gt;.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontColor=#7f1d1d;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="7995" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="lattice-summary-invalid" value="&lt;b&gt;Summary write invalid&lt;/b&gt;&lt;br&gt;&lt;code&gt;phase_summary_write.status=invalid&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Repair content or linked plan issues before claiming saved evidence.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontColor=#7f1d1d;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="7995" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="lattice-post-write-invalid" value="&lt;b&gt;Post-write validation warns&lt;/b&gt;&lt;br&gt;&lt;code&gt;artifact_validate.valid=false&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Name issues and suggested repairs. State sync must stay honest.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="7995" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="lattice-filtered-run" value="&lt;b&gt;Filtered run completed&lt;/b&gt;&lt;br&gt;&lt;code&gt;requestedWave&lt;/code&gt; or &lt;code&gt;gapsOnly&lt;/code&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Report only selected coverage. Do not imply full phase execution.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1250" y="7995" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="lattice-all-done" value="&lt;b&gt;All selected plans have valid completed summaries&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Rerun summary index, validate artifacts, sync state, then route to validation. Still no phase-complete claim from execute-phase.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1640" y="7995" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="lattice-route-ambiguous" value="&lt;b&gt;Route ambiguous&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Use &lt;code&gt;/blu-progress&lt;/code&gt; rather than recommending planned-only commands or making up a next action.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2030" y="7995" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="lattice-user-stop" value="&lt;b&gt;User stops or skips&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;Preserve durable evidence only through summary writes that match actual work. Do not keep hidden in-memory continuation as the only record.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=10;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2420" y="7995" width="360" height="150" as="geometry" />
        </mxCell>

        <!-- Glossary and artifact map -->
        <mxCell id="glossary-tools" value="&lt;b&gt;Execute-phase MCP glossary&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;blueprint_phase_locate&lt;/code&gt;: find the target phase folder safely.&lt;br&gt;&lt;code&gt;blueprint_phase_plan_index&lt;/code&gt;: list saved plans, waves, dependencies, and explicit gap-closure plans.&lt;br&gt;&lt;code&gt;blueprint_phase_summary_index&lt;/code&gt;: list summaries and compute completed versus pending plans.&lt;br&gt;&lt;code&gt;blueprint_phase_execution_targets&lt;/code&gt;: deterministically select candidates, selected plans, blockers, overwrite candidates, and conflict groups.&lt;br&gt;&lt;code&gt;blueprint_phase_plan_read&lt;/code&gt;: read one selected plan with metadata and validation.&lt;br&gt;&lt;code&gt;blueprint_phase_summary_read&lt;/code&gt;: read one existing summary with status and validation.&lt;br&gt;&lt;code&gt;blueprint_artifact_contract_read&lt;/code&gt;: read the official &lt;code&gt;phase.summary&lt;/code&gt; template.&lt;br&gt;&lt;code&gt;blueprint_phase_summary_write&lt;/code&gt;: write one validated summary for one existing valid plan.&lt;br&gt;&lt;code&gt;blueprint_config_get&lt;/code&gt;: read normalized execution settings.&lt;br&gt;&lt;code&gt;blueprint_artifact_validate&lt;/code&gt;: check artifact health before and after writes.&lt;br&gt;&lt;code&gt;blueprint_state_load&lt;/code&gt;: read current blockers and derived status.&lt;br&gt;&lt;code&gt;blueprint_state_update&lt;/code&gt;: sync &lt;code&gt;STATE.md&lt;/code&gt; from current artifact truth.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontColor=#0f172a;spacing=12;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="8640" width="980" height="470" as="geometry" />
        </mxCell>
        <mxCell id="glossary-artifacts" value="&lt;b&gt;Artifact map&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;&lt;code&gt;XX-YY-PLAN.md&lt;/code&gt;: saved plan. Source of plan id, wave, dependencies, files, acceptance criteria, and gap-closure marker.&lt;br&gt;&lt;code&gt;XX-YY-SUMMARY.md&lt;/code&gt;: execution evidence for exactly one plan. Only valid &lt;code&gt;COMPLETED&lt;/code&gt; closes execution debt.&lt;br&gt;&lt;code&gt;.blueprint/STATE.md&lt;/code&gt;: project-local derived routing state after sync.&lt;br&gt;&lt;code&gt;.blueprint/config.json&lt;/code&gt;: normalized execution behavior such as parallelization and worktree posture.&lt;br&gt;&lt;br&gt;&lt;b&gt;Not an artifact here&lt;/b&gt;: execute-phase report files, raw checkpoint files, and generated summary paths outside the selected phase directory.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#10b981;fontColor=#064e3b;spacing=12;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="8640" width="680" height="470" as="geometry" />
        </mxCell>
        <mxCell id="glossary-example" value="&lt;b&gt;Concrete example flow&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;User runs &lt;code&gt;/blu-execute-phase 3 --wave 2&lt;/code&gt;.&lt;br&gt;Phase resolves to &lt;code&gt;03-phase-discovery&lt;/code&gt;.&lt;br&gt;Plan index finds &lt;code&gt;03-01-PLAN.md&lt;/code&gt;, &lt;code&gt;03-02-PLAN.md&lt;/code&gt;, and &lt;code&gt;03-03-PLAN.md&lt;/code&gt;.&lt;br&gt;Summary index says plan 01 is completed and plan 02 is still pending in wave 1.&lt;br&gt;Execution targets returns &lt;code&gt;lowerWavePendingPlans=[02]&lt;/code&gt;.&lt;br&gt;Command stops wave 2 work and tells the user to execute or repair plan 02 first. No summary is written for wave 2.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontColor=#7c2d12;spacing=12;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1820" y="8640" width="620" height="470" as="geometry" />
        </mxCell>
        <mxCell id="glossary-completion" value="&lt;b&gt;Completion checklist&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;&quot;&gt;1. Phase was resolved with MCP.&lt;br&gt;2. Plan and summary indexes were read before mutation.&lt;br&gt;3. &lt;code&gt;blueprint_phase_execution_targets&lt;/code&gt; selected targets and surfaced blockers.&lt;br&gt;4. Selected plans and existing summaries were read.&lt;br&gt;5. Execution honored waves, config, ownership boundaries, and verification.&lt;br&gt;6. &lt;code&gt;phase.summary&lt;/code&gt; contract was read before summary authoring.&lt;br&gt;7. One summary per executed plan was written through MCP.&lt;br&gt;8. Summary index, artifact validation, and synced state update ran in that order.&lt;br&gt;9. Final routing avoided phase-completion claims and stayed inside implemented commands.&lt;/span&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;spacing=12;fontSize=12;fontFamily=Inter;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2480" y="8640" width="660" height="470" as="geometry" />
        </mxCell>

        <!-- Main path arrows -->
        <mxCell id="edge-entry-to-resolve" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="entry-manifest" target="resolve-call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-resolve-to-read" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="resolve-output" target="read-mcp-primary">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-read-to-decide" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="read-execution-targets" target="decide-target-output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-decide-to-execute" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="decide-ready" target="execute-real-work">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-execute-to-persist" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="execute-verification" target="persist-contract-call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-contract-to-write" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="persist-contract-details" target="persist-write-call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-write-to-artifact" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="persist-write-internals" target="persist-summary-artifact">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-persist-to-validate" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="persist-summary-artifact" target="validate-summary-index-call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-validate-order-1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="validate-summary-index-call" target="validate-artifact-call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-validate-order-2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="validate-artifact-call" target="validate-state-call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-validate-to-route" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=3;endArrow=block;endFill=1;" edge="1" parent="1" source="validate-state-artifact" target="route-next-validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Gate arrows -->
        <mxCell id="edge-unresolved-stop" value="if unresolved" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#dc2626;strokeWidth=2;endArrow=block;endFill=1;fontColor=#7f1d1d;fontSize=12;fontFamily=Inter;" edge="1" parent="1" source="resolve-internals" target="resolve-stop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-overwrite-to-confirm" value="overwrite gate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ea580c;strokeWidth=2;endArrow=block;endFill=1;fontColor=#7c2d12;fontSize=12;fontFamily=Inter;" edge="1" parent="1" source="decide-summary-reuse" target="decide-overwrite">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-conflict-to-mode" value="ownership gate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ea580c;strokeWidth=2;endArrow=block;endFill=1;fontColor=#7c2d12;fontSize=12;fontFamily=Inter;" edge="1" parent="1" source="decide-conflict" target="execute-agent-path">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-fail-to-partial" value="failed checks become truthful evidence" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#dc2626;strokeWidth=2;endArrow=block;endFill=1;fontColor=#7f1d1d;fontSize=12;fontFamily=Inter;" edge="1" parent="1" source="execute-verification" target="persist-write-call">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
